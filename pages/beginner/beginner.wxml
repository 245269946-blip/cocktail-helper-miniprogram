<view class="page">
  <view class="section-title">不知道喝什么，就从这三步选</view>
  <view class="section-subtitle">这里不做百科，直接把模糊需求拆成酒感、味道和购买方式。</view>

  <view class="section card">
    <view class="title">你能接受酒味吗？</view>
    <view class="tags option-tags">
      <view wx:for="{{levelOptions}}" wx:key="label" class="tag {{item.active ? 'active' : ''}}" data-group="level" data-value="{{item.label}}" bindtap="onOptionTap">{{item.label}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="title">你喜欢什么味道？</view>
    <view class="tags option-tags">
      <view wx:for="{{flavorOptions}}" wx:key="label" class="tag {{item.active ? 'active' : ''}}" data-group="flavor" data-value="{{item.label}}" bindtap="onOptionTap">{{item.label}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="title">你现在方便怎么买？</view>
    <view class="tags option-tags">
      <view wx:for="{{buyOptions}}" wx:key="label" class="tag {{item.active ? 'active' : ''}}" data-group="buy" data-value="{{item.label}}" bindtap="onOptionTap">{{item.label}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">新手推荐酒单</view>
    <view class="list">
      <view wx:for="{{results}}" wx:key="id" class="card result-card" data-id="{{item.id}}" bindtap="onDetailTap">
        <view class="visual-row">
          <view class="beginner-copy">
            <view class="title">{{item.name}}</view>
            <view class="section-subtitle">{{item.entryLine}}</view>
          </view>
          <view class="drink-illo small-illo {{item.visualClass}}">
            <view class="illo-bubble bubble-a"></view>
            <view class="illo-bubble bubble-b"></view>
            <view class="illo-cup">
              <view class="illo-liquid"></view>
              <view class="illo-ice ice-a"></view>
              <view class="illo-ice ice-b"></view>
            </view>
            <view class="illo-fruit"></view>
            <view class="illo-leaf"></view>
            <view class="illo-shelf"></view>
          </view>
        </view>
        <view class="tags">
          <view wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
