<view class="page">
  <view class="section-title">找一杯好喝的</view>
  <view class="section-subtitle">从甜口、清爽、微醺开始，再帮你缩小到能做的方案。</view>

  <view class="section list">
    <view wx:for="{{collections}}" wx:key="title" class="card collection-card" data-value="{{item.value}}" data-title="{{item.title}}" bindtap="onTap">
      <view class="row">
        <view>
          <view class="title">{{item.title}}</view>
          <view class="section-subtitle">{{item.desc}}</view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>
  </view>
</view>
