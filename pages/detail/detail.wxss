/* 详情头部（杂志风格，无容器感） */
.detail-hero {
  padding: 24rpx 0;
}

.detail-visual {
  margin-bottom: 22rpx;
  background:
    radial-gradient(circle at 68% 16%, rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0) 110rpx),
    linear-gradient(145deg, rgba(232, 250, 247, 0.8), rgba(255, 246, 230, 0.7));
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding-top: 12rpx;
  margin-bottom: 18rpx;
}

.detail-kicker {
  margin-bottom: 8rpx;
  color: #5fa69b;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-title {
  color: #203b3b;
  font-size: 50rpx;
  font-weight: 800;
  line-height: 1.2;
}

.detail-en {
  margin-top: 6rpx;
  color: #81766c;
  font-size: 26rpx;
  line-height: 1.5;
}

.favorite-button {
  flex: 0 0 auto;
  min-width: 132rpx;
  height: 64rpx;
  margin: 0;
  border: 2rpx solid rgba(61, 119, 118, 0.16);
  border-radius: 999rpx;
  color: #233836;
  background: rgba(255, 253, 247, 0.8);
  font-size: 24rpx;
  line-height: 64rpx;
}

.favorite-button.active {
  color: #fffdf8;
  border-color: #5fa69b;
  background: #2f7770;
}

.reason {
  margin-top: 12rpx;
}

.fact-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

/* 信息卡（轻量标签式，无容器感） */
.fact-card {
  min-height: 92rpx;
  padding: 14rpx 16rpx;
}

.fact-card .fact-label {
  margin-bottom: 6rpx;
}

.fact-card .fact-value {
  font-size: 25rpx;
}

.score-list {
  margin-top: 18rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
}

.score-label {
  width: 86rpx;
  color: #5d5045;
  font-size: 25rpx;
}

.score-stars {
  width: 132rpx;
  color: #e4a356;
  font-size: 24rpx;
  letter-spacing: 1rpx;
}

.score-human {
  flex: 1;
  color: #81766c;
  font-size: 24rpx;
}

/* 行动提示区（淡色强调，非卡片容器） */
.action-card {
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(180, 195, 185, 0.10);
  border-bottom: 1rpx solid rgba(180, 195, 185, 0.10);
}

.material-section {
  margin-top: 20rpx;
}

.material-title {
  margin-bottom: 8rpx;
  color: #233836;
  font-size: 27rpx;
  font-weight: 700;
}

.material-line,
.bullet-line {
  margin-top: 6rpx;
}

.step-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.step-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 42rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #fffdf8;
  background: #2f7770;
  font-size: 23rpx;
}

.step-text {
  flex: 1;
  padding-top: 1rpx;
}

.scene-tags {
  margin-top: 16rpx;
}

/* 翻车提醒（淡暖色，轻量提示，非卡片容器） */
.warning-card {
  padding: 24rpx 0;
}

.similar-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.explore-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

/* 探索推荐（轻量网格项，非卡片） */
.explore-card {
  min-height: 116rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(180, 195, 185, 0.10);
}

.explore-card-title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}

/* ============================================================
   V2 详情页：杂志式配方页，但保持“现在能做”的工具主线
   ============================================================ */

.detail-page {
  min-height: 100vh;
  padding: 0 28rpx 76rpx;
  background:
    radial-gradient(circle at 78% 4%, rgba(234, 245, 247, 0.92) 0, rgba(234, 245, 247, 0) 340rpx),
    linear-gradient(180deg, #fbf7ee 0%, #fffaf0 52%, #f8f0e3 100%);
}

.detail-page::before {
  content: '';
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  pointer-events: none;
  opacity: 0.32;
  background-image:
    radial-gradient(circle, rgba(93, 80, 69, 0.07) 0 1rpx, transparent 1rpx);
  background-size: 18rpx 18rpx;
}

.detail-hero.lab-shell {
  position: relative;
  z-index: 1;
  margin: 0 -28rpx 18rpx;
  padding: 20rpx 0 24rpx;
  overflow: visible;
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.detail-visual.asset-illo.large-asset,
.detail-visual {
  position: relative;
  width: auto;
  height: 410rpx;
  margin: 0 48rpx 0;
  overflow: hidden;
  border: 1rpx solid rgba(47, 143, 123, 0.06);
  border-radius: 48rpx;
  background:
    linear-gradient(100deg, rgba(255, 252, 244, 0.96) 0%, rgba(255, 252, 244, 0.66) 42%, rgba(234, 245, 247, 0.18) 100%),
    radial-gradient(circle at 74% 44%, rgba(190, 230, 216, 0.7), rgba(190, 230, 216, 0) 260rpx),
    linear-gradient(145deg, rgba(234, 246, 240, 0.86), rgba(248, 232, 199, 0.5));
  box-shadow: 0 12rpx 30rpx rgba(80, 70, 50, 0.055);
}

.detail-visual::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 116rpx;
  z-index: 1;
  background: linear-gradient(180deg, rgba(255, 252, 244, 0), rgba(255, 252, 244, 0.34));
  pointer-events: none;
}

.detail-visual::after {
  content: '';
  position: absolute;
  left: 0;
  right: 72%;
  top: 0;
  bottom: 0;
  z-index: 1;
  opacity: 0.22;
  background: linear-gradient(90deg, rgba(255, 252, 244, 0.62), rgba(255, 252, 244, 0.18), rgba(255, 252, 244, 0));
  pointer-events: none;
}

.detail-visual .asset-image {
  position: relative;
  z-index: 3;
  width: 92%;
  height: 92%;
  margin: 14rpx auto 0;
  opacity: 1;
  transform: none;
}

.detail-head {
  position: relative;
  z-index: 3;
  margin: 18rpx 28rpx 18rpx;
  padding: 30rpx 28rpx 28rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.08);
  border-radius: 36rpx;
  background: rgba(255, 252, 244, 0.86);
  box-shadow: 0 10rpx 30rpx rgba(80, 70, 50, 0.055);
  backdrop-filter: blur(14rpx);
}

.detail-kicker {
  display: inline-flex;
  margin-bottom: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #2f8f7b;
  background: rgba(190, 230, 216, 0.42);
  font-size: 22rpx;
  font-weight: 800;
}

.detail-title {
  color: #182b26;
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 900;
}

.detail-en {
  margin-top: 10rpx;
  color: #61726b;
  font-size: 27rpx;
  line-height: 1.45;
}

.favorite-button {
  min-width: 126rpx;
  height: 62rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.12);
  background: rgba(255, 252, 244, 0.72);
  box-shadow: 0 6rpx 16rpx rgba(80, 70, 50, 0.04);
  color: #244d43;
  font-weight: 700;
  line-height: 62rpx;
}

.favorite-button.active {
  border-color: transparent;
  background: #2f8f7b;
}

.detail-hero .tags {
  position: relative;
  z-index: 3;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 0 28rpx;
}

.detail-page .tag {
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.1);
  border-radius: 999rpx;
  color: #3d766f;
  background: rgba(255, 252, 244, 0.62);
  font-size: 22rpx;
  font-weight: 700;
}

.fact-grid {
  position: relative;
  z-index: 2;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin: 20rpx 0 24rpx;
}

.fact-card {
  min-height: 104rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.065);
  border-radius: 26rpx;
  background: rgba(255, 252, 244, 0.68);
  box-shadow: 0 6rpx 18rpx rgba(80, 70, 50, 0.035);
}

.fact-card .fact-label {
  color: #7b8a84;
  font-size: 22rpx;
}

.fact-card .fact-value {
  color: #233d36;
  font-size: 27rpx;
  font-weight: 800;
}

.section.card,
.detail-page .card {
  border: 1rpx solid rgba(80, 70, 50, 0.055);
  border-radius: 34rpx;
  background: rgba(255, 252, 244, 0.76);
  box-shadow: 0 8rpx 24rpx rgba(80, 70, 50, 0.045);
}

.section.card {
  position: relative;
  z-index: 1;
  padding: 30rpx 28rpx;
  margin-top: 24rpx;
}

.section .title,
.section-title {
  color: #203b35;
  font-size: 32rpx;
  line-height: 1.24;
  font-weight: 900;
}

.body,
.section-subtitle,
.small,
.muted {
  color: #65736d;
  font-size: 25rpx;
  line-height: 1.55;
}

.action-card {
  overflow: hidden;
  border-color: rgba(47, 143, 123, 0.08);
  background:
    linear-gradient(100deg, rgba(234, 246, 240, 0.95), rgba(255, 252, 244, 0.9) 62%, rgba(248, 232, 199, 0.56));
  box-shadow: 0 10rpx 28rpx rgba(47, 143, 123, 0.065);
}

.action-card::after {
  content: '';
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(246, 212, 107, 0.42), rgba(246, 212, 107, 0));
}

.action-card .title {
  color: #244d43;
}

.action-card .body {
  margin-top: 10rpx;
  color: #314842;
  font-weight: 700;
}

.step-row {
  gap: 18rpx;
  margin-top: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(47, 143, 123, 0.08);
}

.step-row:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.step-index {
  flex: 0 0 54rpx;
  width: 54rpx;
  height: 54rpx;
  background: linear-gradient(135deg, #2f8f7b, #3fb2a0);
  box-shadow: 0 8rpx 18rpx rgba(47, 143, 123, 0.16);
  font-size: 25rpx;
  font-weight: 800;
}

.step-text {
  padding-top: 5rpx;
  color: #374d46;
}

.material-version-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.material-section {
  min-width: 0;
  margin-top: 0;
  padding: 16rpx 12rpx 14rpx;
  border-radius: 22rpx;
  background:
    linear-gradient(140deg, rgba(255, 250, 240, 0.96), rgba(234, 246, 240, 0.54));
  border: 1rpx solid rgba(47, 143, 123, 0.08);
}

.material-doodle {
  position: relative;
  height: 76rpx;
  margin-bottom: 10rpx;
}

.doodle-main,
.doodle-side,
.doodle-mark {
  position: absolute;
  box-sizing: border-box;
}

.material-standard .doodle-main {
  left: 32rpx;
  top: 10rpx;
  width: 50rpx;
  height: 58rpx;
  border: 4rpx solid rgba(47, 143, 123, 0.34);
  border-top-width: 2rpx;
  border-radius: 8rpx 8rpx 18rpx 18rpx;
  transform: rotate(-5deg);
}

.material-standard .doodle-side {
  left: 86rpx;
  top: 32rpx;
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid rgba(246, 212, 107, 0.72);
  border-radius: 50%;
}

.material-standard .doodle-mark {
  left: 40rpx;
  top: 26rpx;
  width: 34rpx;
  height: 3rpx;
  background: rgba(47, 143, 123, 0.22);
  box-shadow: 0 12rpx 0 rgba(47, 143, 123, 0.16);
}

.material-store .doodle-main {
  left: 38rpx;
  top: 12rpx;
  width: 44rpx;
  height: 58rpx;
  border: 4rpx solid rgba(217, 169, 95, 0.46);
  border-radius: 14rpx 14rpx 10rpx 10rpx;
  background: rgba(248, 232, 199, 0.32);
  transform: rotate(4deg);
}

.material-store .doodle-side {
  left: 88rpx;
  top: 26rpx;
  width: 34rpx;
  height: 38rpx;
  border: 3rpx solid rgba(47, 143, 123, 0.22);
  border-radius: 8rpx;
  transform: rotate(-6deg);
}

.material-store .doodle-mark {
  left: 48rpx;
  top: 26rpx;
  width: 22rpx;
  height: 4rpx;
  background: rgba(217, 169, 95, 0.55);
  box-shadow: 0 13rpx 0 rgba(217, 169, 95, 0.38);
}

.material-home .doodle-main {
  left: 42rpx;
  top: 20rpx;
  width: 56rpx;
  height: 46rpx;
  border: 4rpx solid rgba(47, 143, 123, 0.3);
  border-radius: 10rpx 10rpx 14rpx 14rpx;
  background: rgba(190, 230, 216, 0.18);
}

.material-home .doodle-side {
  left: 50rpx;
  top: 8rpx;
  width: 42rpx;
  height: 42rpx;
  border-left: 4rpx solid rgba(47, 143, 123, 0.28);
  border-top: 4rpx solid rgba(47, 143, 123, 0.28);
  transform: rotate(45deg);
}

.material-home .doodle-mark {
  left: 66rpx;
  top: 46rpx;
  width: 16rpx;
  height: 20rpx;
  border: 3rpx solid rgba(47, 143, 123, 0.2);
  border-radius: 8rpx 8rpx 0 0;
}

.material-title {
  overflow: hidden;
  color: #244d43;
  font-size: 24rpx;
  line-height: 1.18;
  font-weight: 900;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.material-cue {
  margin-top: 5rpx;
  color: #8a7e70;
  font-size: 18rpx;
  line-height: 1.2;
  font-weight: 700;
}

.material-lines {
  margin-top: 10rpx;
}

.material-line {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 5rpx;
  color: #607069;
  font-size: 20rpx;
  line-height: 1.32;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.bullet-line {
  color: #607069;
  font-size: 24rpx;
  line-height: 1.55;
}

.score-row {
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(47, 143, 123, 0.08);
}

.score-row:last-child {
  border-bottom: none;
}

.score-label {
  width: 96rpx;
  color: #244d43;
  font-size: 25rpx;
  font-weight: 800;
}

.score-stars {
  display: none;
}

.score-meter {
  position: relative;
  flex: 0 0 148rpx;
  height: 16rpx;
  margin-top: 11rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(234, 245, 247, 0.88);
}

.score-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #bee6d8, #2f8f7b);
}

.score-human {
  flex: 1;
  color: #68766f;
  font-size: 24rpx;
  line-height: 1.45;
}

.explore-grid {
  gap: 16rpx;
}

.explore-card {
  min-height: 132rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.1);
  border-radius: 28rpx;
  background:
    linear-gradient(135deg, rgba(255, 252, 244, 0.92), rgba(234, 245, 247, 0.66));
}

.explore-card-title {
  color: #233d36;
  font-size: 28rpx;
  font-weight: 900;
}

.warning-card {
  border-color: rgba(217, 169, 95, 0.16);
  background:
    linear-gradient(135deg, rgba(255, 252, 244, 0.9), rgba(248, 232, 199, 0.58));
}

.similar-card {
  padding: 24rpx;
  border-radius: 28rpx;
}

/* Detail layout tune-up */
.detail-head {
  display: block;
  padding: 28rpx 28rpx 30rpx;
}

.detail-head > view {
  width: 100%;
}

.detail-title {
  padding-right: 152rpx;
  line-height: 1.12;
  letter-spacing: 0;
}

.detail-en {
  max-width: 100%;
  padding-right: 0;
  line-height: 1.5;
}

.favorite-button {
  position: absolute;
  top: 30rpx;
  right: 28rpx;
  min-width: 132rpx;
  height: 60rpx;
  border: 2rpx solid rgba(47, 143, 123, 0.14);
  border-radius: 999rpx;
  background:
    linear-gradient(145deg, rgba(255, 252, 244, 0.92), rgba(234, 246, 240, 0.72));
  box-shadow:
    0 7rpx 0 rgba(47, 143, 123, 0.06),
    0 12rpx 22rpx rgba(80, 70, 50, 0.06);
  line-height: 58rpx;
}

.favorite-button.active {
  border-color: rgba(47, 143, 123, 0.2);
  background: linear-gradient(135deg, #2f8f7b, #3fb2a0);
  box-shadow:
    0 7rpx 0 rgba(36, 77, 67, 0.11),
    0 12rpx 22rpx rgba(47, 143, 123, 0.14);
}

.fact-card {
  min-height: 112rpx;
}

.fact-card .fact-label,
.fact-card .fact-value,
.section .title,
.body,
.section-subtitle,
.material-line,
.bullet-line,
.step-text {
  letter-spacing: 0;
}

.section.card {
  border-radius: 28rpx;
}

/* Stronger quick-start module */
.action-card.section.card {
  padding: 30rpx 26rpx 28rpx;
  border: 2rpx solid rgba(47, 143, 123, 0.13);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 88% 22%, rgba(246, 212, 107, 0.34), rgba(246, 212, 107, 0) 120rpx),
    linear-gradient(118deg, rgba(226, 246, 236, 0.98), rgba(255, 252, 244, 0.95) 58%, rgba(248, 232, 199, 0.62));
  box-shadow:
    0 12rpx 0 rgba(47, 143, 123, 0.035),
    0 20rpx 42rpx rgba(47, 143, 123, 0.09);
}

.action-card-head {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.action-kicker {
  display: inline-flex;
  min-height: 36rpx;
  padding: 0 14rpx;
  align-items: center;
  border-radius: 999rpx;
  color: #2f8f7b;
  background: rgba(255, 252, 244, 0.68);
  font-size: 19rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.action-sticker {
  flex: 0 0 auto;
  min-width: 82rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(47, 143, 123, 0.13);
  border-radius: 16rpx 16rpx 24rpx 24rpx;
  color: #2f8f7b;
  background: rgba(255, 252, 244, 0.78);
  font-size: 18rpx;
  font-weight: 900;
  transform: rotate(5deg);
  box-shadow: 0 8rpx 16rpx rgba(80, 70, 50, 0.07);
}

.action-flow {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.action-flow-item {
  min-height: 116rpx;
  padding: 14rpx 10rpx 12rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.09);
  border-radius: 24rpx;
  background: rgba(255, 252, 244, 0.66);
  text-align: center;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.42);
}

.action-flow-icon {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(190, 230, 216, 0.55);
  font-size: 26rpx;
}

.action-flow-text {
  display: -webkit-box;
  overflow: hidden;
  color: #29443c;
  font-size: 20rpx;
  line-height: 1.25;
  font-weight: 800;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.action-flow-sub {
  margin-top: 6rpx;
  color: rgba(41, 68, 60, 0.58);
  font-size: 17rpx;
  line-height: 1.25;
}

.action-card .action-body {
  position: relative;
  z-index: 2;
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  color: #253d36;
  background: rgba(255, 252, 244, 0.62);
  font-size: 26rpx;
  line-height: 1.48;
}
