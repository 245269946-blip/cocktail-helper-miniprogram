.detail-visual {
  margin-bottom: 22rpx;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding-top: 12rpx;
  margin-bottom: 18rpx;
}

.detail-title {
  font-size: 50rpx;
  font-weight: 800;
  line-height: 1.2;
}

.detail-en {
  margin-top: 6rpx;
  color: #81766c;
  font-size: 26rpx;
  line-height: 1.5;
}

.favorite-button {
  flex: 0 0 auto;
  min-width: 132rpx;
  height: 64rpx;
  margin: 0;
  border: 2rpx solid rgba(76, 62, 47, 0.12);
  border-radius: 999rpx;
  color: #2b2520;
  background: rgba(255, 253, 247, 0.9);
  font-size: 24rpx;
  line-height: 64rpx;
}

.favorite-button.active {
  color: #fffdf8;
  border-color: #eaa8ba;
  background: #eaa8ba;
}

.reason {
  margin-top: 12rpx;
}

.score-list {
  margin-top: 18rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
}

.score-label {
  width: 86rpx;
  color: #5d5045;
  font-size: 25rpx;
}

.score-stars {
  width: 132rpx;
  color: #e4a356;
  font-size: 24rpx;
  letter-spacing: 1rpx;
}

.score-human {
  flex: 1;
  color: #81766c;
  font-size: 24rpx;
}

.action-card {
  border-color: #c7e4dc;
  background: linear-gradient(145deg, #f6fff7 0%, #e7f5f1 100%);
}

.material-section {
  margin-top: 20rpx;
}

.material-title {
  margin-bottom: 8rpx;
  color: #2b2520;
  font-size: 27rpx;
  font-weight: 700;
}

.material-line,
.bullet-line {
  margin-top: 6rpx;
}

.step-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.step-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 42rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #fffdf8;
  background: #2f4f4a;
  font-size: 23rpx;
}

.step-text {
  flex: 1;
  padding-top: 1rpx;
}

.scene-tags {
  margin-top: 16rpx;
}

.warning-card {
  border-color: #f0c5b0;
  background: linear-gradient(145deg, #fff8f2 0%, #fff1ea 100%);
}

.similar-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.explore-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.explore-card {
  min-height: 116rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #f7f2ff 100%);
}

.explore-card-title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}
