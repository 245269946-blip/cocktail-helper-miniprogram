.detail-hero {
  padding: 22rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 38rpx;
  background:
    radial-gradient(circle at 82% 12%, rgba(142, 219, 213, 0.28) 0, rgba(142, 219, 213, 0) 170rpx),
    linear-gradient(145deg, rgba(255, 253, 247, 0.9), rgba(238, 250, 248, 0.72));
  box-shadow: 0 18rpx 46rpx rgba(57, 96, 102, 0.09);
}

.detail-visual {
  margin-bottom: 22rpx;
  background:
    radial-gradient(circle at 68% 16%, rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0) 110rpx),
    linear-gradient(145deg, rgba(232, 250, 247, 0.8), rgba(255, 246, 230, 0.7));
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding-top: 12rpx;
  margin-bottom: 18rpx;
}

.detail-kicker {
  margin-bottom: 8rpx;
  color: #5fa69b;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-title {
  color: #203b3b;
  font-size: 50rpx;
  font-weight: 800;
  line-height: 1.2;
}

.detail-en {
  margin-top: 6rpx;
  color: #81766c;
  font-size: 26rpx;
  line-height: 1.5;
}

.favorite-button {
  flex: 0 0 auto;
  min-width: 132rpx;
  height: 64rpx;
  margin: 0;
  border: 2rpx solid rgba(61, 119, 118, 0.16);
  border-radius: 999rpx;
  color: #233836;
  background: rgba(255, 253, 247, 0.8);
  font-size: 24rpx;
  line-height: 64rpx;
}

.favorite-button.active {
  color: #fffdf8;
  border-color: #5fa69b;
  background: #2f7770;
}

.reason {
  margin-top: 12rpx;
}

.fact-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.fact-card {
  min-height: 92rpx;
  padding: 16rpx 18rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 22rpx;
  background: rgba(255, 253, 247, 0.68);
}

.fact-card .fact-label {
  margin-bottom: 6rpx;
}

.fact-card .fact-value {
  font-size: 25rpx;
}

.score-list {
  margin-top: 18rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
}

.score-label {
  width: 86rpx;
  color: #5d5045;
  font-size: 25rpx;
}

.score-stars {
  width: 132rpx;
  color: #e4a356;
  font-size: 24rpx;
  letter-spacing: 1rpx;
}

.score-human {
  flex: 1;
  color: #81766c;
  font-size: 24rpx;
}

.action-card {
  border-color: rgba(80, 169, 165, 0.22);
  background:
    radial-gradient(circle at 88% 18%, rgba(142, 219, 213, 0.26) 0, rgba(142, 219, 213, 0) 130rpx),
    linear-gradient(145deg, rgba(246, 255, 251, 0.86) 0%, rgba(225, 246, 242, 0.78) 100%);
}

.material-section {
  margin-top: 20rpx;
}

.material-title {
  margin-bottom: 8rpx;
  color: #233836;
  font-size: 27rpx;
  font-weight: 700;
}

.material-line,
.bullet-line {
  margin-top: 6rpx;
}

.step-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.step-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 42rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #fffdf8;
  background: #2f7770;
  font-size: 23rpx;
}

.step-text {
  flex: 1;
  padding-top: 1rpx;
}

.scene-tags {
  margin-top: 16rpx;
}

.warning-card {
  border-color: #f0c5b0;
  background: linear-gradient(145deg, rgba(255, 248, 242, 0.88) 0%, rgba(255, 241, 234, 0.78) 100%);
}

.similar-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.explore-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.explore-card {
  min-height: 116rpx;
  background: linear-gradient(145deg, rgba(255, 253, 247, 0.86) 0%, rgba(239, 249, 247, 0.78) 100%);
}

.explore-card-title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}
