.ingredient-hero {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.intro-tags {
  margin-top: 18rpx;
}

.recipe-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.recipe-copy {
  flex: 1;
  min-width: 0;
}

.bullet-line {
  margin-top: 8rpx;
}

.warning-card {
  border-color: #f0c5b0;
  background: linear-gradient(145deg, #fff8f2 0%, #fff1ea 100%);
}
