<view class="page results-page {{themeClass}}">
  <view class="result-head lab-shell">
    <view>
      <view class="result-kicker">Search Result</view>
      <view class="section-title">{{title}}</view>
      <view class="section-subtitle">{{subtitle}}</view>
    </view>
    <view class="sketch-icon icon-glass"></view>
  </view>

  <view wx:if="{{mainRecommendation || results.length}}" class="section list">
    <view wx:if="{{mainRecommendation}}" class="lead-card card result-card" data-id="{{mainRecommendation.id}}" bindtap="onDetailTap">
      <view class="lead-label">先看这杯</view>
      <view class="visual-row">
        <view class="result-copy">
          <view class="title">{{mainRecommendation.name}}</view>
          <view class="small muted">{{mainRecommendation.audienceText}}</view>
        </view>
        <view class="asset-illo lead-asset">
          <image class="asset-image" src="{{mainRecommendation.illustration}}" mode="aspectFit" />
        </view>
      </view>
      <view class="result-entry">{{mainRecommendation.entryLine}}</view>
      <view class="execute-line">{{mainRecommendation.executionLine}}</view>
      <view class="lead-action" data-id="{{mainRecommendation.id}}" catchtap="onDetailTap">查看材料步骤</view>
    </view>

    <view wx:if="{{results.length}}" class="section-title more-title">更多可选方案</view>
    <view wx:for="{{results}}" wx:key="id" class="card result-card" data-id="{{item.id}}" bindtap="onDetailTap">
      <view class="visual-row">
        <view class="result-copy">
          <view class="title">{{item.name}}</view>
          <view class="small muted">{{item.audienceText}}</view>
        </view>
        <view class="asset-illo">
          <image class="asset-image" src="{{item.illustration}}" mode="aspectFit" />
        </view>
      </view>
      <view class="type-label">{{item.type === 'scheme' ? '方案' : '配方'}}</view>
      <view class="result-entry">{{item.entryLine}}</view>
      <view class="fact-strip">
        <view wx:for="{{item.basicFacts}}" wx:for-item="fact" wx:key="label" class="fact-pill">
          <text class="fact-label">{{fact.label}}</text>
          <text class="fact-value">{{fact.value}}</text>
        </view>
      </view>
      <view class="execute-line">{{item.executionLine}}</view>
      <view class="result-action" data-id="{{item.id}}" catchtap="onDetailTap">查看材料步骤</view>
      <view class="score-mini">
        <view wx:for="{{item.scoreRows}}" wx:for-item="score" wx:key="key" class="score-mini-row">
          <text class="score-mini-label">{{score.label}}</text>
          <text class="score-stars">{{score.stars}}</text>
          <text class="score-note">{{score.note}}</text>
        </view>
      </view>
    </view>

    <view class="section-title explore-title">继续探索</view>
    <view class="explore-grid">
      <view wx:for="{{exploreOptions}}" wx:key="title" class="card explore-card" data-value="{{item.value}}" data-title="{{item.title}}" bindtap="onExploreTap">
        <view class="explore-card-title">{{item.title}}</view>
        <view class="small muted">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view wx:else class="section card empty-card">
    <view class="title">还没找到合适结果</view>
    <view class="section-subtitle">可以试试“金酒”“可乐”“甜口”“便利店调酒”这类关键词。</view>
    <button class="button-primary empty-button" bindtap="onSearchAgain">重新搜索</button>
  </view>
</view>
