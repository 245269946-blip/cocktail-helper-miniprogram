.result-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  overflow: hidden;
}

.result-copy {
  flex: 1;
  min-width: 0;
}

.type-label {
  flex: 0 0 auto;
  align-self: flex-start;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #2f4f4a;
  background: #e4f4ef;
  font-size: 22rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-button {
  margin-top: 8rpx;
}

.result-entry {
  color: #2b2520;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.execute-line {
  color: #d98c24;
  font-size: 24rpx;
  line-height: 1.45;
}

.score-mini {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-top: 4rpx;
}

.score-mini-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 23rpx;
  line-height: 1.4;
}

.score-mini-label {
  width: 64rpx;
  color: #5d5045;
}

.score-stars {
  width: 116rpx;
  color: #e4a356;
  letter-spacing: 1rpx;
}

.score-note {
  flex: 1;
  color: #81766c;
}

.explore-title {
  margin-top: 12rpx;
}

.explore-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.explore-card {
  min-height: 110rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #f1faf7 100%);
}

.explore-card-title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}
