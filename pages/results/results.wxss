.results-page {
  padding-top: 24rpx;
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 24rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 88% 10%, rgba(142, 219, 213, 0.28) 0, rgba(142, 219, 213, 0) 150rpx),
    linear-gradient(145deg, rgba(255, 253, 247, 0.88), rgba(238, 250, 248, 0.76));
}

.result-kicker {
  margin-bottom: 8rpx;
  color: #5fa69b;
  font-size: 22rpx;
  font-weight: 700;
}

.result-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  overflow: hidden;
}

.result-card::after {
  position: absolute;
  right: -32rpx;
  top: -42rpx;
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: rgba(142, 219, 213, 0.12);
  content: "";
}

.lead-card {
  gap: 18rpx;
  padding: 28rpx;
  border-color: rgba(80, 169, 165, 0.24);
  background:
    radial-gradient(circle at 84% 18%, rgba(142, 219, 213, 0.3) 0, rgba(142, 219, 213, 0) 150rpx),
    linear-gradient(145deg, rgba(255, 253, 247, 0.9), rgba(229, 249, 246, 0.76));
}

.lead-label {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #255b58;
  background: rgba(207, 242, 237, 0.86);
  font-size: 22rpx;
  font-weight: 700;
}

.lead-asset {
  width: 156rpx;
  height: 132rpx;
}

.more-title {
  margin-top: 8rpx;
  margin-bottom: 0;
  font-size: 30rpx;
}

.result-copy {
  flex: 1;
  min-width: 0;
}

.type-label {
  flex: 0 0 auto;
  align-self: flex-start;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #255b58;
  background: #dff5f1;
  font-size: 22rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-button {
  margin-top: 8rpx;
}

.result-entry {
  color: #2b2520;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.execute-line {
  color: #c77b35;
  font-size: 24rpx;
  line-height: 1.45;
}

.lead-action,
.result-action {
  align-self: flex-start;
  min-height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #fffdf8;
  background: #2f7770;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 50rpx;
}

.result-action {
  color: #255b58;
  background: rgba(207, 242, 237, 0.82);
}

.score-mini {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-top: 4rpx;
}

.score-mini-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 23rpx;
  line-height: 1.4;
}

.score-mini-label {
  width: 64rpx;
  color: #5d5045;
}

.score-stars {
  width: 116rpx;
  color: #e4a356;
  letter-spacing: 1rpx;
}

.score-note {
  flex: 1;
  color: #81766c;
}

.explore-title {
  margin-top: 12rpx;
}

.explore-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.explore-card {
  min-height: 110rpx;
  background: linear-gradient(145deg, rgba(255, 253, 247, 0.86) 0%, rgba(235, 249, 246, 0.78) 100%);
}

.explore-card-title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}
