<view class="page">
  <view class="section-title">你有什么材料？</view>
  <view class="section-subtitle">从可乐、雪碧、橙汁、咖啡、牛奶这些自然入口开始。</view>

  <view class="section list">
    <view wx:for="{{categories}}" wx:key="title" class="card">
      <view class="title category-title">{{item.title}}</view>
      <view class="ingredient-grid">
        <view wx:for="{{item.items}}" wx:for-item="choice" wx:key="name" class="ingredient-choice" data-name="{{choice.name}}" bindtap="onIngredientTap">
          <image class="ingredient-image" src="{{choice.illustration}}" mode="aspectFit" />
          <view class="ingredient-name">{{choice.name}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
