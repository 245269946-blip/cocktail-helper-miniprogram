.category-title {
  margin-bottom: 18rpx;
}

.card {
  background: linear-gradient(145deg, #fffdf8 0%, #fff7ee 100%);
}

.ingredient-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.ingredient-choice {
  min-width: 0;
  padding: 10rpx 8rpx 12rpx;
  border: 2rpx solid rgba(76, 62, 47, 0.1);
  border-radius: 22rpx;
  background: rgba(255, 253, 247, 0.72);
}

.ingredient-image {
  display: block;
  width: 100%;
  height: 92rpx;
}

.ingredient-name {
  margin-top: 4rpx;
  color: #5d5045;
  font-size: 22rpx;
  line-height: 1.25;
  text-align: center;
}
