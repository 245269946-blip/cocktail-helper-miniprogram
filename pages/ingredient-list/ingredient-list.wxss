.category-title {
  margin-bottom: 18rpx;
}

.card {
  background:
    radial-gradient(circle at 88% 16%, rgba(255, 197, 155, 0.18) 0, rgba(255, 197, 155, 0) 130rpx),
    linear-gradient(145deg, rgba(255, 253, 247, 0.86) 0%, rgba(255, 244, 232, 0.76) 100%);
}

.ingredient-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.ingredient-choice {
  min-width: 0;
  padding: 10rpx 8rpx 12rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.11);
  border-radius: 22rpx;
  background: rgba(255, 253, 247, 0.66);
}

.ingredient-image {
  display: block;
  width: 100%;
  height: 92rpx;
}

.ingredient-name {
  margin-top: 4rpx;
  color: #5d5045;
  font-size: 22rpx;
  line-height: 1.25;
  text-align: center;
}
