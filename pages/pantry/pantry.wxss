.group-title {
  margin-bottom: 18rpx;
}

.drink-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.pantry-copy {
  flex: 1;
  min-width: 0;
}

.pantry-section-desc {
  margin-top: -8rpx;
  margin-bottom: 16rpx;
}

.missing {
  color: #c77b35;
}

.pantry-action {
  align-self: flex-start;
  min-height: 44rpx;
  padding: 7rpx 16rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 999rpx;
  color: #255b58;
  background: #dff5f1;
  font-size: 23rpx;
}

.empty {
  margin: -2rpx 0 12rpx;
  color: #9b9287;
  font-size: 25rpx;
}
