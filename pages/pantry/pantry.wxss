.pantry-page {
  padding: 28rpx 28rpx 76rpx;
  background:
    radial-gradient(circle at 88% 8%, rgba(246, 212, 107, 0.18) 0, rgba(246, 212, 107, 0) 260rpx),
    radial-gradient(circle at 8% 18%, rgba(190, 230, 216, 0.34) 0, rgba(190, 230, 216, 0) 250rpx),
    linear-gradient(180deg, #fbf7ee 0%, #fffaf0 52%, #f8f1e4 100%);
}

.pantry-hero {
  padding: 22rpx 8rpx 18rpx;
}

.pantry-kicker {
  color: #2f8f7b;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.2;
}

.pantry-search {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 78rpx;
  margin: 12rpx 0 24rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(47, 143, 123, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.82);
  box-shadow:
    0 8rpx 0 rgba(47, 143, 123, 0.04),
    0 14rpx 28rpx rgba(80, 70, 50, 0.055),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.52);
}

.pantry-search-icon {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #244d43;
  font-size: 34rpx;
  line-height: 1;
}

.pantry-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  color: #233836;
  font-size: 27rpx;
}

.selected-strip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.selected-scroll {
  flex: 1;
  white-space: nowrap;
}

.selected-track {
  display: inline-flex;
  gap: 10rpx;
}

.selected-pill,
.pantry-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(47, 143, 123, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.72);
  color: #51645e;
  font-size: 24rpx;
  line-height: 1;
  box-shadow: 0 5rpx 0 rgba(80, 70, 50, 0.025);
}

.selected-pill,
.pantry-tag.active {
  border-color: rgba(47, 143, 123, 0.32);
  background: rgba(190, 230, 216, 0.62);
  color: #244d43;
  font-weight: 800;
}

.clear-button {
  width: 116rpx;
  height: 54rpx;
  margin: 0;
  border: 2rpx solid rgba(47, 143, 123, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.78);
  color: #607069;
  font-size: 23rpx;
  line-height: 1 !important;
}

.pantry-picker {
  padding: 26rpx 24rpx 10rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.08);
  border-radius: 34rpx;
  background:
    linear-gradient(150deg, rgba(255, 252, 244, 0.88), rgba(234, 246, 240, 0.54));
  box-shadow: 0 12rpx 30rpx rgba(80, 70, 50, 0.05);
}

.pantry-group {
  margin-bottom: 28rpx;
}

.pantry-group-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.pantry-group-title {
  color: #203b35;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.pantry-group-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(47, 143, 123, 0.18), rgba(47, 143, 123, 0));
}

.pantry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pantry-results,
.pantry-default {
  margin-top: 30rpx;
}

.small-title {
  font-size: 31rpx;
  line-height: 1.22;
}

.pantry-section-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
}

.pantry-result-section {
  margin-bottom: 34rpx;
}

.pantry-result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.pantry-drink-card {
  position: relative;
  min-height: 190rpx;
  overflow: hidden;
  border: 1rpx solid rgba(47, 143, 123, 0.08);
  border-radius: 30rpx;
  background:
    linear-gradient(100deg, rgba(255, 252, 244, 0.98) 0%, rgba(255, 252, 244, 0.88) 54%, rgba(234, 246, 240, 0.44) 100%);
  box-shadow: 0 10rpx 24rpx rgba(80, 70, 50, 0.045);
}

.pantry-card-copy {
  position: relative;
  z-index: 2;
  width: 66%;
  padding: 24rpx 24rpx 22rpx;
}

.pantry-card-action {
  display: inline-flex;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #2f7065;
  background: rgba(190, 230, 216, 0.54);
  font-size: 21rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.pantry-card-title {
  margin-top: 12rpx;
  color: #172a25;
  font-size: 34rpx;
  line-height: 1.15;
  font-weight: 900;
}

.pantry-card-desc,
.pantry-missing {
  margin-top: 8rpx;
  color: #65736d;
  font-size: 23rpx;
  line-height: 1.42;
}

.pantry-missing {
  color: #c77b35;
  font-weight: 700;
}

.pantry-card-img {
  position: absolute;
  right: 0;
  top: 0;
  width: 42%;
  height: 100%;
  opacity: 0.85;
}

.starter-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.starter-track {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 24rpx;
}

.starter-card {
  position: relative;
  width: 330rpx;
  min-height: 300rpx;
  overflow: hidden;
  border: 1rpx solid rgba(47, 143, 123, 0.08);
  border-radius: 30rpx;
  background: rgba(255, 252, 244, 0.82);
  box-shadow: 0 10rpx 24rpx rgba(80, 70, 50, 0.05);
}

.starter-img {
  width: 100%;
  height: 170rpx;
  opacity: 0.88;
}

.starter-copy {
  padding: 16rpx 18rpx 20rpx;
}

.starter-name {
  color: #203b35;
  font-size: 30rpx;
  line-height: 1.18;
  font-weight: 900;
}

.starter-desc {
  margin-top: 8rpx;
  color: #6c7c75;
  font-size: 22rpx;
  line-height: 1.36;
}
