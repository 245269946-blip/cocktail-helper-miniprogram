.base-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #f4fbff 100%);
}

.base-search {
  display: flex;
  align-items: center;
  min-height: 74rpx;
  margin: 22rpx 0 8rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.82);
  box-shadow: 0 8rpx 18rpx rgba(80, 70, 50, 0.045);
}

.base-search-input {
  flex: 1;
  min-width: 0;
  height: 70rpx;
  color: #233836;
  font-size: 25rpx;
}

.base-copy {
  flex: 1;
  min-width: 0;
}

.card-tags {
  gap: 10rpx;
}

.arrow {
  color: #8bbdb4;
  font-size: 46rpx;
}
