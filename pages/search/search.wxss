.catalog-page {
  padding: 26rpx 28rpx 88rpx;
  background:
    radial-gradient(circle at 92% 6%, rgba(246, 212, 107, 0.16) 0, rgba(246, 212, 107, 0) 240rpx),
    radial-gradient(circle at 8% 14%, rgba(190, 230, 216, 0.30) 0, rgba(190, 230, 216, 0) 230rpx),
    linear-gradient(180deg, #fbf7ee 0%, #fffaf2 46%, #f6f1e8 100%);
}

.catalog-hero {
  padding: 14rpx 4rpx 16rpx;
}

.catalog-kicker {
  margin-bottom: 6rpx;
  color: #2f8f7b;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
}

.catalog-search {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 74rpx;
  padding: 10rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.10);
  border-radius: 28rpx;
  background: rgba(255, 252, 244, 0.92);
  box-shadow: 0 10rpx 24rpx rgba(80, 70, 50, 0.055);
}

.catalog-input {
  flex: 1;
  min-width: 0;
  height: 58rpx;
  padding: 0 16rpx;
  color: #233836;
  font-size: 25rpx;
}

.catalog-clear,
.catalog-submit {
  height: 56rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 56rpx;
}

.catalog-clear {
  color: #68766f;
  background: rgba(234, 246, 240, 0.56);
}

.catalog-submit {
  color: #fff;
  background: linear-gradient(135deg, #55b8a5, #2f8f7b);
  font-weight: 800;
}

.catalog-strip {
  margin-top: 22rpx;
}

.strip-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.strip-title {
  color: #203b35;
  font-size: 25rpx;
  font-weight: 800;
}

.strip-action {
  color: #9aa8a2;
  font-size: 22rpx;
}

.chip-scroll {
  white-space: nowrap;
}

.chip-track {
  display: inline-flex;
  gap: 10rpx;
  padding-right: 24rpx;
}

.catalog-chip {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.72);
  color: #51645e;
  font-size: 22rpx;
}

.catalog-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-top: 30rpx;
}

.catalog-group-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.catalog-group-title {
  color: #172a25;
  font-size: 34rpx;
  line-height: 1.16;
  font-weight: 900;
}

.catalog-group-subtitle {
  margin-top: 4rpx;
  color: #7b8a84;
  font-size: 22rpx;
  line-height: 1.35;
}

.catalog-count {
  min-width: 46rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: rgba(47, 143, 123, 0.10);
  color: #2f7065;
  text-align: center;
  font-size: 22rpx;
  line-height: 42rpx;
  font-weight: 800;
}

.catalog-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.catalog-card {
  position: relative;
  min-height: 258rpx;
  overflow: hidden;
  border: 1rpx solid rgba(47, 143, 123, 0.09);
  border-radius: 26rpx;
  background: linear-gradient(150deg, rgba(255, 252, 244, 0.95), rgba(234, 246, 240, 0.70));
  box-shadow: 0 8rpx 18rpx rgba(80, 70, 50, 0.045);
}

.catalog-img {
  display: block;
  width: 100%;
  height: 142rpx;
}

.catalog-card-copy {
  padding: 16rpx 16rpx 18rpx;
}

.catalog-name {
  color: #172a25;
  font-size: 29rpx;
  line-height: 1.14;
  font-weight: 900;
}

.catalog-en {
  margin-top: 2rpx;
  color: #8a9892;
  font-size: 19rpx;
  line-height: 1.2;
  font-style: italic;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.catalog-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 10rpx;
}

.catalog-tag {
  max-width: 120rpx;
  height: 30rpx;
  padding: 0 10rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.10);
  border-radius: 999rpx;
  color: #49776f;
  background: rgba(255, 252, 244, 0.58);
  font-size: 18rpx;
  line-height: 30rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.catalog-empty {
  margin-top: 44rpx;
  padding: 34rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 252, 244, 0.72);
}

.catalog-empty-title {
  margin-bottom: 8rpx;
  color: #203b35;
  font-size: 30rpx;
  font-weight: 900;
}
