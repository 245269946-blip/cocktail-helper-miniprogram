.search-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 2rpx 8rpx;
}

.search-kicker {
  margin-bottom: 8rpx;
  color: #5fa69b;
  font-size: 22rpx;
  font-weight: 700;
}

.search-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(76, 62, 47, 0.1);
  border-radius: 30rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #f0faf8 100%);
  box-shadow: 0 16rpx 36rpx rgba(91, 70, 48, 0.07);
}

.search-input {
  height: 92rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(76, 62, 47, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #fff8f0 100%);
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 700;
}
