.search-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 24rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 86% 12%, rgba(142, 219, 213, 0.26) 0, rgba(142, 219, 213, 0) 150rpx),
    linear-gradient(145deg, rgba(255, 253, 247, 0.88), rgba(238, 250, 248, 0.72));
}

.search-kicker {
  margin-bottom: 8rpx;
  color: #5fa69b;
  font-size: 22rpx;
  font-weight: 700;
}

.search-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.14);
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255, 253, 247, 0.84) 0%, rgba(231, 249, 246, 0.74) 100%);
  box-shadow: 0 16rpx 36rpx rgba(57, 96, 102, 0.08);
  transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
}

.search-panel.focused {
  border-color: rgba(65, 176, 166, 0.52);
  box-shadow: 0 18rpx 46rpx rgba(80, 169, 165, 0.18), 0 0 0 6rpx rgba(151, 230, 222, 0.16);
  transform: translateY(-2rpx);
}

.search-input {
  height: 92rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(145deg, rgba(255, 253, 247, 0.86) 0%, rgba(255, 246, 230, 0.72) 100%);
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 700;
}
