<view class="page">
  <view class="section-title">已经知道想搜什么？</view>
  <view class="section-subtitle">鸡尾酒名、基酒、材料、口味、便利店都可以搜。</view>

  <view class="search-panel">
    <input class="search-input" value="{{keyword}}" bindinput="onInput" confirm-type="search" bindconfirm="onSearch" placeholder="搜金酒 / 可乐 / 甜口 / 便利店 / 莫吉托" />
    <button class="button-primary" bindtap="onSearch">查看结果</button>
  </view>

  <view class="section">
    <view class="section-title">从一个词继续展开</view>
    <view class="suggestion-list">
      <view wx:for="{{suggestionGroups}}" wx:key="title" class="card suggestion-group">
        <view class="suggestion-title">{{item.title}}</view>
        <view class="tags">
          <view wx:for="{{item.items}}" wx:for-item="word" wx:key="*this" class="tag" data-keyword="{{word}}" bindtap="onKeywordTap">{{word}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">常用入口</view>
    <view class="tags">
      <view wx:for="{{hotKeywords}}" wx:key="*this" class="tag" data-keyword="{{item}}" bindtap="onKeywordTap">{{item}}</view>
    </view>
  </view>
</view>
