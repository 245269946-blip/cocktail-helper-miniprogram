<view class="page search-page lab-page">
  <view class="search-hero lab-shell">
    <view>
      <view class="search-kicker">Search First</view>
      <view class="section-title">搜你想喝的 / 手边有的</view>
      <view class="section-subtitle">饮品名、材料、口味、便利店、气泡饮、茶饮、咖啡都可以搜。</view>
    </view>
    <view class="sketch-icon icon-glass"></view>
  </view>

  <view class="search-panel {{isFocused ? 'focused' : ''}}">
    <input class="search-input" value="{{keyword}}" bindinput="onInput" bindfocus="onFocus" bindblur="onBlur" confirm-type="search" bindconfirm="onSearch" placeholder="搜气泡水 / 柠檬茶 / 咖啡 / 便利店 / 莫吉托" />
    <button class="button-primary" bindtap="onSearch">查看结果</button>
  </view>

  <view class="section">
    <view class="section-title">从一个词继续展开</view>
    <view class="suggestion-list">
      <view wx:for="{{suggestionGroups}}" wx:key="title" class="card suggestion-group">
        <view class="suggestion-title">{{item.title}}</view>
        <view class="tags">
          <view wx:for="{{item.items}}" wx:for-item="word" wx:key="*this" class="tag" data-keyword="{{word}}" bindtap="onKeywordTap">{{word}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">常用入口</view>
    <view class="tags">
      <view wx:for="{{hotKeywords}}" wx:key="*this" class="tag" data-keyword="{{item}}" bindtap="onKeywordTap">{{item}}</view>
    </view>
  </view>
</view>
