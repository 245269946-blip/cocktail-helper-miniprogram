/* ============================================================
   基酒详情页样式 - 对应 layer3-3-ref.png (威士忌)
   ============================================================ */

.base-detail-page {
  min-height: 100vh;
  background: #faf7f2;
  padding-bottom: 60rpx;
}

/* ========== 导航 ========== */
.bd-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  height: 88rpx;
  box-sizing: border-box;
}
.nav-back { font-size: 48rpx; color: #3d4a44; width: 64rpx; }
.nav-title { font-size: 32rpx; font-weight: 600; color: #2d3a36; }
.nav-actions { display: flex; align-items: center; gap: 16rpx; width: 80rpx; justify-content: flex-end; }
.nav-star { font-size: 32rpx; color: #e0c86e; }
.nav-more { font-size: 36rpx; color: #8aa09a; }

/* ========== Tab 搜索栏 ========== */
.tab-search-bar {
  white-space: nowrap;
  padding: 0 24rpx 20rpx;
}

.tab-item {
  display: inline-block;
  padding: 12rpx 26rpx;
  margin-right: 14rpx;
  font-size: 25rpx;
  color: #6b7570;
  border: 2rpx solid rgba(180,195,185,0.2);
  border-radius: 28rpx;
  white-space: nowrap;
  background: #fff;
}
.tab-item.active {
  color: #2f7d6d;
  border-color: rgba(95,184,166,0.4);
  background: rgba(207,242,237,0.3);
}


/* ========== 主推荐 Hero 卡 ========== */
.hero-card {
  margin: 0 28rpx 28rpx;
  padding: 26rpx 26rpx 30rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #faf5ef 50%, #f5ede0 100%);
  border: 2rpx solid rgba(212,175,130,0.18);
  border-radius: 28rpx;
  box-shadow: 0 10rpx 36rpx rgba(57,96,102,0.06);
  position: relative;
  overflow: hidden;
}

.hero-badge-row { margin-bottom: 18rpx; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, #fff8ee, #ffefdb);
  border-radius: 22rpx;
  border: 1rpx solid rgba(212,175,130,0.25);
}

.badge-text {
  font-size: 23rpx;
  font-weight: 600;
  color: #9a6830;
}
.badge-star { font-size: 22rpx; }

.hero-body {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.hero-name {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: #1a2820;
  line-height: 1.15;
  letter-spacing: 2rpx;
}

.hero-name-en {
  display: block;
  font-size: 25rpx;
  color: #9a8878;
  font-style: italic;
  margin-bottom: 12rpx;
}

.hero-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 14rpx; }

.h-tag {
  padding: 5rpx 16rpx;
  font-size: 21rpx;
  color: #8a7858;
  background: rgba(245,235,215,0.7);
  border-radius: 16rpx;
  border: 1rpx solid rgba(212,175,130,0.15);
}

.hero-desc {
  font-size: 24rpx;
  color: #6b6560;
  line-height: 1.55;
  margin-bottom: 20rpx;
}

.hero-cta {
  align-self: flex-start;
  height: 68rpx;
  padding: 0 32rpx;
  margin: 0;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #5fb8a6, #3d9b89);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 68rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(63,155,137,0.22);
}

/* 右侧图片 */
.hero-right {
  position: relative;
  width: 260rpx;
  flex-shrink: 0;
}

.hero-img {
  width: 100%;
  height: 300rpx;
  filter: drop-shadow(0 8rpx 20rpx rgba(57,96,102,0.1));
}

.img-speech-bubble {
  position: absolute;
  bottom: 40rpx;
  right: -10rpx;
  padding: 12rpx 18rpx;
  font-size: 20rpx;
  color: #7a6050;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(6rpx);
  border-radius: 16rpx;
  border: 1rpx solid rgba(180,160,140,0.2);
  max-width: 200rpx;
  line-height: 1.4;
  transform: rotate(2deg);
}


/* ========== 快捷筛选行 ========== */
.quick-filters {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin: 0 28rpx 28rpx;
}

.qf-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 16rpx;
  background: #fff;
  border: 2rpx solid rgba(180,195,185,0.15);
  border-radius: 22rpx;
  overflow: hidden;
}
.qf-item:active { background: #fafaf7; }

.qf-name {
  font-size: 25rpx;
  font-weight: 600;
  color: #2d3a36;
  flex-shrink: 0;
}
.qf-desc {
  font-size: 20rpx;
  color: #9aa8a2;
  flex-shrink: 0;
}
.qf-arrow {
  margin-left: auto;
  font-size: 36rpx;
  color: #c0cec8;
}


/* ========== 更多搭配列表 ========== */
.more-pairings-section {
  padding: 0 28rpx 20rpx;
}

.pairing-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.pairing-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d3a36;
}

.pairing-refresh {
  font-size: 23rpx;
  color: #9aa8a2;
}

.pairing-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pairing-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx;
  background: #fff;
  border: 2rpx solid rgba(180,195,185,0.13);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(57,96,102,0.04);
}

.pc-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.pc-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pc-top {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.pc-name {
  font-size: 29rpx;
  font-weight: 700;
  color: #2d3a36;
}
.pc-name-en {
  font-size: 23rpx;
  color: #a09890;
  font-style: italic;
}

.pc-tags { display: flex; flex-wrap: wrap; gap: 6rpx; }

.pc-tag {
  font-size: 19rpx;
  padding: 3rpx 12rpx;
  color: #7a9a8e;
  background: #f0f5f3;
  border-radius: 12rpx;
}

.pc-desc {
  font-size: 23rpx;
  color: #8a9892;
  line-height: 1.45;
}

.pc-arrow {
  font-size: 40rpx;
  color: #c0cec8;
  flex-shrink: 0;
}


/* ========== 空状态 ========== */
.empty-wrap {
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-text { font-size: 28rpx; color: #9aa8a2; }

/* v1.0.4 final image and text safety */
.hero-card,
.pairing-card {
  position: relative;
  overflow: hidden;
}

.hero-img,
.pc-img {
  display: block;
  opacity: 1;
}

.nav-title,
.tab-item,
.qf-name,
.qf-desc {
  letter-spacing: 0;
}
