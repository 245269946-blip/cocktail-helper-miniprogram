/* ============================================================
   便利店调酒页样式 - 对应 layer3-2-ref.png
   ============================================================ */

.conv-page {
  min-height: 100vh;
  background: #faf7f2;
  position: relative;
}

/* ========== 导航 ========== */
.conv-nav {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  height: 88rpx;
  box-sizing: border-box;
}
.nav-back { font-size: 48rpx; color: #3d4a44; width: 64rpx; }
.nav-title { font-size: 32rpx; font-weight: 600; color: #2d3a36; }
.nav-more { font-size: 36rpx; color: #8aa09a; width: 64rpx; text-align: right; }

/* ========== 背景冰箱场景 ========== */
.conv-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 480rpx;
  z-index: 0;
  overflow: hidden;
}
.bg-img { width: 100%; height: 100%; opacity: 0.35; }
.bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(250,247,242,0.1) 0%, rgba(250,247,242,0.95) 70%, #faf7f2 100%);
}

/* ========== 筛选区（便利贴风格）========== */
.filter-area {
  position: relative;
  z-index: 5;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 28rpx 16rpx;
  gap: 16rpx;
}

.filter-sticky-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 便利贴通用 */
.sticky-note {
  padding: 18rpx 22rpx 16rpx;
  background: linear-gradient(135deg, #fffef6 0%, #fdf9ec 100%);
  border-radius: 14rpx;
  box-shadow:
    0 4rpx 16rpx rgba(60,70,60,0.08),
    inset 0 -30rpx 30rpx -30rpx rgba(200,195,180,0.12);
  transform: rotate(-1deg);
  /* 顶部锯齿 */
  clip-path: polygon(
    0% 0%, 5% 3%, 10% 0%, 15% 3%, 20% 0%, 25% 3%, 30% 0%, 35% 3%, 40% 0%,
    45% 3%, 50% 0%, 55% 3%, 60% 0%, 65% 3%, 70% 0%, 75% 3%, 80% 0%, 85% 3%,
    90% 0%, 95% 3%, 100% 0%,
    100% 100%, 0% 100%
  );
}

.note-pin { font-size: 24rpx; margin-bottom: 4rpx; }
.note-q {
  display: block;
  font-size: 23rpx;
  color: #5a6862;
  margin-bottom: 8rpx;
}

.dropdown-select {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 20rpx;
  border: 1rpx solid rgba(180,195,185,0.25);
}

.select-value { font-size: 24rpx; color: #2d3a36; font-weight: 500; }
.select-arrow { font-size: 20rpx; color: #9aa8a2; }

.note-mood { transform: rotate(1deg); }

/* 右侧装饰便利贴 */
.deco-sticky-right {
  padding: 16rpx 20rpx 14rpx;
  background: linear-gradient(135deg, #fffef8 0%, #f8f4e8 100%);
  border-radius: 12rpx;
  transform: rotate(3deg);
  max-width: 220rpx;
  box-shadow: 0 4rpx 16rpx rgba(60,70,60,0.08);
}

.deco-text-line1,
.deco-text-line2 {
  display: block;
  font-size: 22rpx;
  color: #5fa69b;
  line-height: 1.5;
}
.deco-text-line2 { font-weight: 600; }

.deco-barcode {
  display: flex;
  gap: 3rpx;
  margin-top: 10rpx;
  align-items: flex-end;
  height: 32rpx;
}
.barcode-line {
  flex: 1;
  background: #c0ccc6;
  border-radius: 2rpx;
}
.barcode-line.thin { opacity: 0.5; }
.barcode-line.thick { flex: 0.3; }


/* ========== 主推荐方案区（杂志风格） ========== */
.scheme-hero-card {
  position: relative;
  z-index: 5;
  margin: 0 32rpx 32rpx;
  padding: 32rpx 28rpx 36rpx;
  background:
    radial-gradient(circle at 92% 10%, rgba(95,184,166,0.06) 0, transparent 240rpx),
    linear-gradient(165deg, #f9fbfa 0%, #f2f7f4 50%, #f7faf8 100%);
  border-radius: 18rpx;
}

.scheme-badges {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.badge-plan {
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #5fb8a6, #3d9b89);
  border-radius: 20rpx;
}

.scheme-deco-tag {
  font-size: 23rpx;
  color: #5fb8a6;
  font-weight: 500;
}

.scheme-body {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.scheme-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.scheme-name {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #1a2820;
  line-height: 1.2;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.scheme-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.scheme-tag {
  padding: 5rpx 16rpx;
  font-size: 21rpx;
  color: #4a7870;
  background: rgba(207,242,237,0.55);
  border-radius: 16rpx;
}

.scheme-desc {
  font-size: 24rpx;
  color: #6b7570;
  line-height: 1.55;
  margin-bottom: 20rpx;
}

/* CTA按钮（杂志淡色风格，非电商） */
.scheme-cta {
  align-self: flex-start;
  height: 64rpx;
  padding: 0 28rpx;
  margin: 0;
  border-radius: 32rpx;
  background: rgba(95, 184, 166, 0.12);
  color: #2f7d6d;
  font-size: 25rpx;
  font-weight: 500;
  line-height: 64rpx;
  border: none;
}

.scheme-visual {
  position: relative;
  width: 240rpx;
  flex-shrink: 0;
}

.scheme-img {
  width: 100%;
  height: 280rpx;
  filter: drop-shadow(0 6rpx 16rpx rgba(57,96,102,0.08));
}

.price-tag {
  position: absolute;
  bottom: 8rpx;
  right: 0;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(6rpx);
  border-radius: 14rpx;
  text-align: right;
}

.price-label { display: block; font-size: 19rpx; color: #9aa8a2; }
.price-val { display: block; font-size: 24rpx; font-weight: 700; color: #e67e22; }


/* ========== 更多方案 ========== */
.more-schemes-section {
  padding: 0 28rpx 24rpx;
  z-index: 5;
  position: relative;
}

.section-head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-head-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d3a36;
}

.section-hint-right { font-size: 22rpx; color: #b0beb8; }

.scheme-scroll { white-space: nowrap; }

/* 迷你方案卡片（轻量列表项风格） */
.scheme-mini-card {
  display: inline-flex;
  flex-direction: column;
  width: 260rpx;
  margin-right: 16rpx;
  vertical-align: top;
  border-radius: 16rpx;
  background: transparent;
  overflow: hidden;
}

.mini-info {
  padding: 18rpx 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.mini-name {
  font-size: 27rpx;
  font-weight: 700;
  color: #2d3a36;
}

.mini-desc {
  font-size: 21rpx;
  color: #8a9892;
  line-height: 1.35;
}

.mini-arrow {
  align-self: flex-end;
  margin: 4rpx 14rpx 0 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0f5f3, #e0ebe6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6a9a8a;
}

.mini-img {
  width: 100%;
  height: 140rpx;
  opacity: 0.85;
}


/* ========== 为什么推荐（留白区块，无容器感） ========== */
.why-section {
  margin: 0 32rpx 28rpx;
  padding: 28rpx 0;
  z-index: 5;
  position: relative;
}

.why-title {
  display: block;
  font-size: 29rpx;
  font-weight: 700;
  color: #2d3a36;
  margin-bottom: 20rpx;
}

.why-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.why-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 16rpx 8rpx;
  background: #fafaf7;
  border-radius: 18rpx;
}

.why-icon { font-size: 36rpx; margin-bottom: 8rpx; }

.why-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #3d4a44;
  margin-bottom: 4rpx;
}

.why-desc {
  font-size: 20rpx;
  color: #9aa8a2;
  line-height: 1.35;
}


/* ========== 小提示（轻量便利贴风） ========== */
.tip-section {
  margin: 0 32rpx 40rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #fefaf2, #fdf6eb);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 5;
  position: relative;
}

.tip-badge {
  font-size: 24rpx;
  white-space: nowrap;
}

.tip-text {
  font-size: 23rpx;
  color: #8a7860;
  line-height: 1.5;
}

/* Convenience page tune-up */
.conv-page {
  padding: 0 0 72rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 88% 8%, rgba(190, 230, 216, 0.36) 0, rgba(190, 230, 216, 0) 260rpx),
    linear-gradient(180deg, #fbf7ee 0%, #fffaf0 48%, #f8f1e4 100%);
}

.conv-nav {
  display: none;
}

.conv-bg {
  position: relative;
  top: auto;
  height: 350rpx;
  border-bottom-left-radius: 46rpx;
  border-bottom-right-radius: 46rpx;
  box-shadow: 0 14rpx 36rpx rgba(80, 70, 50, 0.055);
}

.bg-img {
  opacity: 0.24;
  filter: saturate(0.82) contrast(0.96);
}

.bg-overlay {
  background:
    linear-gradient(180deg, rgba(251, 247, 238, 0.18) 0%, rgba(251, 247, 238, 0.68) 58%, #fbf7ee 100%),
    linear-gradient(90deg, rgba(251, 247, 238, 0.94) 0%, rgba(251, 247, 238, 0.48) 56%, rgba(251, 247, 238, 0.78) 100%);
}

.filter-area {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 226rpx;
  gap: 18rpx;
  margin-top: -148rpx;
  padding: 0 32rpx 18rpx;
}

.filter-sticky-left {
  width: 292rpx;
  gap: 14rpx;
}

.sticky-note {
  padding: 18rpx 20rpx 16rpx;
  border: 1rpx solid rgba(80, 70, 50, 0.06);
  border-radius: 18rpx;
  box-shadow:
    0 9rpx 0 rgba(80, 70, 50, 0.035),
    0 18rpx 36rpx rgba(80, 70, 50, 0.08),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.58);
}

.note-q {
  font-size: 24rpx;
  line-height: 1.38;
}

.dropdown-select {
  max-width: 100%;
  min-height: 46rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.82);
}

.select-value {
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.deco-sticky-right {
  max-width: none;
  margin-top: 34rpx;
  padding: 18rpx 18rpx 16rpx;
  border: 1rpx solid rgba(80, 70, 50, 0.06);
  border-radius: 18rpx;
  box-shadow:
    0 9rpx 0 rgba(80, 70, 50, 0.035),
    0 18rpx 36rpx rgba(80, 70, 50, 0.08);
}

.deco-text-line1,
.deco-text-line2 {
  font-size: 22rpx;
  line-height: 1.42;
}

.scheme-hero-card {
  margin: 22rpx 28rpx 34rpx;
  padding: 30rpx 26rpx 32rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.10);
  border-radius: 34rpx;
  background:
    linear-gradient(105deg, rgba(255, 252, 244, 0.96), rgba(234, 246, 240, 0.82) 64%, rgba(255, 248, 232, 0.74));
  box-shadow:
    0 12rpx 32rpx rgba(80, 70, 50, 0.06),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.scheme-body {
  align-items: center;
  gap: 18rpx;
}

.scheme-name {
  font-size: 36rpx;
  line-height: 1.18;
  letter-spacing: 0;
}

.scheme-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
}

.scheme-cta {
  min-width: 300rpx;
  height: 68rpx;
  border: 2rpx solid rgba(47, 143, 123, 0.14);
  border-radius: 999rpx;
  background:
    linear-gradient(145deg, rgba(255, 252, 244, 0.82), rgba(190, 230, 216, 0.72));
  box-shadow:
    0 8rpx 0 rgba(47, 143, 123, 0.06),
    0 14rpx 24rpx rgba(47, 143, 123, 0.11);
  line-height: 66rpx;
  white-space: nowrap;
}

.scheme-visual {
  width: 224rpx;
}

.scheme-img {
  height: 250rpx;
}

.price-tag {
  border: 1rpx solid rgba(80, 70, 50, 0.06);
  border-radius: 18rpx;
}

.section-head-title {
  line-height: 1.22;
}

.section-hint-right {
  white-space: nowrap;
}

.scheme-mini-card {
  width: 312rpx;
  min-height: 320rpx;
  margin-right: 18rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.08);
  background:
    linear-gradient(150deg, rgba(255, 252, 244, 0.92), rgba(234, 245, 247, 0.70));
  box-shadow: 0 10rpx 24rpx rgba(80, 70, 50, 0.045);
  white-space: normal;
}

.mini-info {
  min-height: 134rpx;
  padding: 20rpx 18rpx 10rpx;
}

.mini-name {
  display: block;
  font-size: 27rpx;
  line-height: 1.22;
  white-space: normal;
}

.mini-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.38;
  white-space: normal;
}

.mini-arrow {
  border: 2rpx solid rgba(47, 143, 123, 0.10);
  box-shadow: 0 7rpx 0 rgba(47, 143, 123, 0.05);
}

.mini-img {
  height: 150rpx;
  opacity: 0.9;
}

.why-item,
.tip-section {
  border: 1rpx solid rgba(80, 70, 50, 0.055);
  box-shadow: 0 8rpx 20rpx rgba(80, 70, 50, 0.04);
}

/* Final convenience layout: visible hero + package recommendations */
.conv-bg {
  height: 440rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.bg-img {
  opacity: 0.88;
  filter: saturate(0.98) contrast(1.02);
}

.bg-overlay {
  display: none;
}

.filter-area {
  display: none;
}

.conv-bg::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 126rpx;
  background: linear-gradient(180deg, rgba(251, 247, 238, 0), rgba(251, 247, 238, 0.56));
  pointer-events: none;
}

.conv-hero-copy {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 22rpx;
  z-index: 2;
  padding: 20rpx 22rpx 22rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.08);
  border-radius: 26rpx;
  background: rgba(255, 252, 244, 0.88);
  box-shadow: 0 10rpx 26rpx rgba(80, 70, 50, 0.10);
  backdrop-filter: blur(8rpx);
  color: #203b35;
}

.conv-kicker {
  display: inline-flex;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.76);
  color: #2f8f7b;
  font-size: 21rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.conv-title {
  margin-top: 10rpx;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 900;
}

.conv-subtitle {
  max-width: 560rpx;
  margin-top: 8rpx;
  color: #4f615a;
  font-size: 24rpx;
  line-height: 1.42;
  font-weight: 700;
}

.scheme-hero-card.package-card {
  margin-top: -20rpx;
  padding-bottom: 26rpx;
}

.package-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.package-copy {
  width: 100%;
}

.package-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.package-drink {
  position: relative;
  min-height: 196rpx;
  overflow: hidden;
  border: 1rpx solid rgba(47, 143, 123, 0.08);
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 252, 244, 0.94), rgba(234, 246, 240, 0.66));
}

.package-drink-img {
  width: 100%;
  height: 108rpx;
  opacity: 0.92;
}

.package-drink-copy {
  padding: 10rpx 14rpx 12rpx;
}

.package-drink-name {
  color: #203b35;
  font-size: 23rpx;
  line-height: 1.18;
  font-weight: 900;
}

.package-drink-desc {
  margin-top: 4rpx;
  color: #2f8f7b;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 800;
}

.package-drink-pin {
  position: absolute;
  right: 12rpx;
  top: 86rpx;
  z-index: 2;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2f8f7b;
  background: rgba(255, 252, 244, 0.9);
  box-shadow: 0 6rpx 14rpx rgba(80, 70, 50, 0.08);
  font-size: 22rpx;
  font-weight: 900;
}

.package-drink-tags {
  display: flex;
  gap: 6rpx;
  margin-top: 8rpx;
  overflow: hidden;
}

.package-drink-tag {
  flex: 0 0 auto;
  padding: 4rpx 9rpx;
  border-radius: 999rpx;
  color: #55756e;
  background: rgba(234, 246, 240, 0.72);
  font-size: 17rpx;
  line-height: 1.1;
  font-weight: 700;
}

.package-price {
  position: static;
  display: inline-flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  text-align: left;
}

.scheme-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1 !important;
}

.scheme-scroll {
  white-space: nowrap;
}

.scheme-mini-card {
  display: inline-flex;
  vertical-align: top;
}
