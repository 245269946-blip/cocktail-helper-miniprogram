.result-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background:
    radial-gradient(circle at 86% 14%, rgba(142, 219, 213, 0.24) 0, rgba(142, 219, 213, 0) 130rpx),
    linear-gradient(145deg, rgba(255, 253, 247, 0.86) 0%, rgba(232, 246, 255, 0.78) 100%);
}

.package-copy {
  flex: 1;
  min-width: 0;
}

.package-title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.price {
  color: #c77b35;
  font-weight: 600;
}

.package-action {
  align-self: flex-start;
  min-height: 44rpx;
  padding: 7rpx 16rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 999rpx;
  color: #255b58;
  background: #dff5f1;
  font-size: 23rpx;
}
