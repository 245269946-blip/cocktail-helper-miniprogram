.result-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #f5fbff 100%);
}

.package-copy {
  flex: 1;
  min-width: 0;
}

.package-title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.price {
  color: #d98c24;
  font-weight: 600;
}

.package-action {
  align-self: flex-start;
  min-height: 44rpx;
  padding: 7rpx 16rpx;
  border: 2rpx solid rgba(76, 62, 47, 0.1);
  border-radius: 999rpx;
  color: #2f4f4a;
  background: #e4f4ef;
  font-size: 23rpx;
}
