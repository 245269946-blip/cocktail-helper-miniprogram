.home-head {
  padding: 18rpx 0 10rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  border: 1rpx solid #ded3c2;
  border-radius: 8rpx;
  background: #fffdf8;
}

.search-input {
  flex: 1;
  height: 68rpx;
  padding: 0 18rpx;
  font-size: 27rpx;
}

.search-button {
  width: 128rpx;
  height: 68rpx;
  margin: 0;
  border-radius: 8rpx;
  color: #fffdf8;
  background: #17130f;
  font-size: 26rpx;
  line-height: 68rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-card {
  width: calc((100% - 16rpx) / 2);
  min-height: 154rpx;
  padding: 22rpx;
  border: 1rpx solid #e8e0d3;
  border-radius: 8rpx;
  background: #fffdf8;
}

.action-card.featured {
  border-color: #ead2a6;
  background: #fff0da;
}

.action-card:nth-child(2) {
  border-color: #cfe5df;
  background: #e8f3f0;
}

.action-card:nth-child(4) {
  border-color: #ead0d6;
  background: #fae9ed;
}

.action-title {
  font-size: 30rpx;
  font-weight: 700;
}

.action-desc {
  margin-top: 8rpx;
  color: #756e63;
  font-size: 24rpx;
  line-height: 1.45;
}

.action-note {
  margin-top: 16rpx;
  color: #2f766f;
  font-size: 22rpx;
  font-weight: 700;
}

.home-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.arrow {
  color: #9f9385;
  font-size: 46rpx;
  line-height: 1;
}
