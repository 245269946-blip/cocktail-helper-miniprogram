/* ============================================================
   调酒助手 - 首页样式（杂志风格，非卡片）
   Layer 1: 启动欢迎页 (水彩风全屏)
   Layer 2: 搜索发现首页 (去卡片化)
   ============================================================ */

/* ========== 全局页面 ========== */
.home-page {
  min-height: 100vh;
  background: #f6f3ed;
}

/* ============================================================
   LAYER 1: 启动欢迎页 (保持不变——启动页本身是全屏沉浸)
   ============================================================ */
.splash-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: linear-gradient(180deg, #faf6ef 0%, #f0e8d8 50%, #e8dfd0 100%);
}

/* --- 背景主视觉 --- */
.splash-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.splash-hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.92;
}

.splash-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(250, 246, 239, 0.3) 0%,
    rgba(250, 246, 239, 0.5) 40%,
    rgba(250, 246, 239, 0.85) 70%,
    rgba(250, 246, 239, 0.95) 100%
  );
}

/* --- 风铃装饰（右上角）--- */
.furin-img {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 160rpx;
  height: 320rpx;
  z-index: 2;
  opacity: 0.85;
  animation: furin-swing 3s ease-in-out infinite;
}

@keyframes furin-swing {
  0%, 100% { transform: rotate(-3deg); }
  50% { transform: rotate(3deg); }
}

/* --- 24h营业标签 --- */
.badge-24h {
  position: absolute;
  top: 200rpx;
  right: 20rpx;
  z-index: 2;
  padding: 10rpx 24rpx;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(8rpx);
  border-radius: 30rpx;
  border: 2rpx solid rgba(180, 210, 200, 0.3);
}

.badge-24h-text {
  font-size: 22rpx;
  color: #5fa69b;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* --- 主内容区 --- */
.splash-content {
  position: relative;
  z-index: 3;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 80rpx 48rpx 120rpx;
}

/* --- 标题组（手写体风格）--- */
.splash-title-group {
  margin-bottom: 16rpx;
}

.splash-title-line1 {
  display: block;
  font-size: 64rpx;
  font-weight: 300;
  color: #2d3a36;
  line-height: 1.15;
  letter-spacing: 4rpx;
  font-style: italic;
}

.splash-title-line2 {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #1a2820;
  line-height: 1.2;
  letter-spacing: 6rpx;
}

/* --- 副标题 --- */
.splash-subtitle {
  font-size: 28rpx;
  color: #7a8a82;
  margin-bottom: 48rpx;
  letter-spacing: 1px;
}

.subtitle-lemon {
  font-size: 26rpx;
  margin-left: 4rpx;
}

/* --- 便利贴小票装饰（保持原样，这是核心氛围元素）--- */
.receipt-note {
  position: relative;
  align-self: flex-start;
  width: 260rpx;
  padding: 24rpx 20rpx 20rpx;
  background: linear-gradient(135deg, #fffef8 0%, #fdf9ee 100%);
  border-radius: 12rpx;
  box-shadow:
    0 4rpx 20rpx rgba(60, 70, 60, 0.08),
    inset 0 -40rpx 40rpx -40rpx rgba(200, 195, 180, 0.15);
  transform: rotate(-2deg);
  margin-bottom: 32rpx;
  clip-path: polygon(
    0% 0%, 4% 3%, 8% 0%, 12% 3%, 16% 0%, 20% 3%, 24% 0%, 28% 3%, 32% 0%,
    36% 3%, 40% 0%, 44% 3%, 48% 0%, 52% 3%, 56% 0%, 60% 3%, 64% 0%,
    68% 3%, 72% 0%, 76% 3%, 80% 0%, 84% 3%, 88% 0%, 92% 3%, 96% 0%,
    100% 3%, 100% 100%, 0% 100%
  );
}

.receipt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2px dashed rgba(160, 155, 140, 0.25);
}

.receipt-title { font-size: 22rpx; color: #4a5550; font-weight: 600; }

.receipt-dots { width: 60rpx; height: 20rpx; border-bottom: 4px dotted #c8c4b4; }

.receipt-items { display: flex; flex-direction: column; gap: 6rpx; }

.receipt-row { display: flex; justify-content: space-between; font-size: 20rpx; }
.r-name { color: #6b7570; }
.r-price { color: #3d4a44; font-weight: 500; }

.receipt-divider {
  height: 2rpx;
  background: repeating-linear-gradient(
    90deg, transparent, transparent 8rpx, rgba(180, 175, 165, 0.3) 8rpx, rgba(180, 175, 165, 0.3) 16rpx
  );
  margin: 10rpx 0;
}

.receipt-total .r-name { font-weight: 600; color: #3d4a44; }
.receipt-total .r-price { font-weight: 700; color: #1a2820; }

.receipt-deco-img {
  position: absolute;
  left: -20rpx;
  bottom: 240rpx;
  width: 180rpx;
  height: 180rpx;
  z-index: 3;
  opacity: 0.9;
  transform: rotate(-8deg);
}

/* --- 对话气泡（保持原样）--- */
.speech-bubble {
  position: absolute;
  right: 0;
  bottom: 280rpx;
  padding: 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 2rpx solid rgba(180, 215, 205, 0.35);
  box-shadow: 0 8rpx 28px rgba(60, 90, 80, 0.08);
  display: flex;
  flex-direction: column;
  gap: 4px;
  max-width: 280rpx;
  transform: rotate(2deg);
}

.speech-bubble::after {
  content: '';
  position: absolute;
  bottom: -18rpx;
  right: 50rpx;
  width: 0;
  height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-top: 20px solid rgba(255, 255, 255, 0.85);
}

.bubble-text { font-size: 24rpx; color: #4a6560; line-height: 1.5; }
.bubble-tag { color: #e8a87c !important; font-weight: 600; }

/* --- CTA 主按钮（保持启动页的醒目度）--- */
.cta-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 100rpx;
  margin: 0;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #5fb8a6 0%, #3d9b89 50%, #2f7d6d 100%);
  box-shadow:
    0 16rpx 40rpx rgba(63, 155, 137, 0.3),
    0 4rpx 12rpx rgba(63, 155, 137, 0.15),
    inset 0 2rpx 4px rgba(255,255,255,0.2);
  border: none;
}

.cta-text { font-size: 32rpx; color: #fff; font-weight: 600; letter-spacing: 2px; }
.cta-arrow { font-size: 32rpx; color: #fff; font-weight: 400; }
.cta-button:active { transform: scale(0.97); box-shadow: 0 8rpx 24rpx rgba(63, 155, 137, 0.25); }

/* --- 底部品牌栏 --- */
.splash-footer {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0 calc(24rpx + env(safe-area-inset-bottom));
}
.footer-dot { font-size: 24px; }
.footer-brand { font-size: 24rpx; color: #5a6862; font-weight: 500; }
.footer-sep { color: #c0ccc6; font-size: 22rpx; }
.footer-slogan { font-size: 22rpx; color: #9aa8a2; }


/* ============================================================
   LAYER 2: 搜索发现首页（去卡片化改造）
   原则：渐变背景 > 边框圆角，呼吸留白 > 容器感
   ============================================================ */
.home-main {
  min-height: 100vh;
  padding-bottom: 64rpx;
  background:
    radial-gradient(circle at 82% 8%, rgba(95, 184, 166, 0.13) 0, transparent 260rpx),
    linear-gradient(180deg, #faf8f2 0%, #f8f5ee 45%, #f6f3ed 100%);
}

/* --- 搜索第一视觉 --- */
.search-hero-section {
  padding: 24rpx 28rpx 28rpx;
}

.home-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx 22rpx;
}

.brand-kicker {
  font-size: 44rpx;
  font-weight: 800;
  color: #2d3a36;
  line-height: 1.15;
}

.brand-slogan {
  font-size: 25rpx;
  color: #75857e;
  margin-top: 10rpx;
  line-height: 1.45;
}

.header-deco-img {
  width: 150rpx;
  height: 120rpx;
  opacity: 0.9;
  flex-shrink: 0;
}

/* --- 搜索区（轻量输入框，非卡片）--- */
.search-section {
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 104rpx;
  padding: 18rpx 18rpx 18rpx 28rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(95, 184, 166, 0.18);
  border-radius: 52rpx;
  box-shadow:
    0 22rpx 58rpx rgba(64, 92, 80, 0.12),
    inset 0 1rpx 0 rgba(255,255,255,0.72);
}

.search-bar.focused {
  border-color: rgba(95, 184, 166, 0.35);
  background: rgba(255, 255, 255, 0.85);
}

.search-icon { font-size: 30rpx; flex-shrink: 0; }

.search-input {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  color: #333;
}

.search-btn {
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 34rpx;
  margin: 0;
  border-radius: 36rpx;
  background: #2f7d6d;
  color: #fff;
  font-size: 27rpx;
  font-weight: 700;
  border: none;
}

.demand-section {
  margin-top: 22rpx;
}

.demand-title {
  font-size: 23rpx;
  color: #8a9892;
  font-weight: 500;
  margin-bottom: 14rpx;
}

.demand-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.demand-chip {
  min-height: 0;
  padding: 0 22rpx 12rpx 0;
  background: transparent;
  border: none;
}

.demand-chip:active {
  opacity: 0.65;
}

.demand-label {
  display: inline;
  font-size: 25rpx;
  color: #2f7d6d;
  font-weight: 600;
  line-height: 1.25;
  border-bottom: 1rpx solid rgba(47, 125, 109, 0.22);
}

.demand-desc {
  display: none;
}

/* 热门搜索行 */
.hot-search-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding: 0 4rpx;
}

.hot-label { font-size: 25rpx; color: #5a6862; font-weight: 500; }

/* 热门标签横滑 */
.hot-tags-scroll { white-space: nowrap; margin-top: 16rpx; }

.hot-tag {
  display: inline-block;
  padding: 0 22rpx 8rpx 0;
  margin-right: 10rpx;
  font-size: 24rpx;
  color: #6f7f78;
  background: transparent;
  border: none;
  white-space: nowrap;
}

.hot-tag:active { color: #2f7d6d; }

/* --- 区块通用 --- */
.section-block { padding: 28rpx 28rpx 0; }

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-label { font-size: 31rpx; font-weight: 800; color: #2d3a36; }
.section-action { font-size: 24rpx; color: #9aa8a2; }

/* 最近搜索 */
.recent-scroll { white-space: nowrap; }

.recent-chip {
  display: inline-flex;
  flex-direction: column;
  padding: 0 28rpx 10rpx 0;
  margin-right: 16rpx;
  background: transparent;
  border: none;
  white-space: nowrap;
}

.chip-name { font-size: 26rpx; color: #3d4a44; font-weight: 500; }
.chip-time { font-size: 20rpx; color: #b0beb8; margin-top: 4rpx; }

/* ========== 今晚热门第一杯 ========== */
.featured-scroll {
  white-space: nowrap;
  padding-bottom: 6rpx;
  border-top: 1rpx solid rgba(180, 195, 185, 0.12);
}

.featured-card {
  position: relative;
  display: inline-flex;
  width: 520rpx;
  min-height: 224rpx;
  margin-right: 34rpx;
  padding: 22rpx 0 24rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid rgba(180, 195, 185, 0.12);
  box-shadow: none;
  overflow: visible;
  vertical-align: top;
}

.featured-card:active { opacity: 0.72; }

.featured-img {
  width: 176rpx;
  height: 198rpx;
  border-radius: 0;
  flex-shrink: 0;
}

.featured-copy {
  flex: 1;
  min-width: 0;
  padding: 0 0 0 22rpx;
  white-space: normal;
}

.featured-demand {
  display: block;
  font-size: 22rpx;
  color: #2f7d6d;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.featured-name {
  display: block;
  font-size: 34rpx;
  color: #172a25;
  font-weight: 800;
  line-height: 1.16;
}

.featured-reason {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #6e7d77;
  line-height: 1.45;
}

.featured-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.featured-tag {
  font-size: 20rpx;
  padding: 0;
  color: #517d75;
  background: transparent;
  border-radius: 0;
}

.featured-tag::before {
  content: '#';
  color: rgba(81, 125, 117, 0.58);
}

/* ========== 工具入口（轻量条目式，非卡片） ========== */
.entry-cards {
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.entry-card {
  position: relative;
  padding: 24rpx 4rpx;
  border-bottom: 1rpx solid rgba(180, 195, 185, 0.10);
}

.entry-card:active { background: rgba(95, 184, 166, 0.04); }

.card-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-info { display: flex; flex-direction: column; gap: 6rpx; }

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2820;
}

.card-desc {
  font-size: 24rpx;
  color: #8a9892;
  line-height: 1.4;
}

/* 右侧箭头 */
.card-arrow {
  font-size: 36rpx;
  color: rgba(150, 170, 160, 0.3);
  flex-shrink: 0;
}

/* --- 今日热配方（横向缩略图条，非卡片网格）--- */
.hot-recipe-scroll { white-space: nowrap; margin-top: 16rpx; }

.recipe-thumb {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  margin-right: 20rpx;
  vertical-align: top;
  overflow: hidden;
  border-bottom: 3rpx solid rgba(180, 195, 185, 0.08);
}

.thumb-img {
  width: 100%;
  height: 260rpx;
}

.thumb-name {
  display: block;
  padding: 14rpx 16rpx 6rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3a36;
}

.thumb-tags {
  display: flex;
  gap: 6rpx;
  padding: 0 16rpx 16rpx;
  flex-wrap: wrap;
}

.thumb-tag {
  font-size: 19rpx;
  padding: 4rpx 14rpx;
  color: #7a9a8e;
  background: #f0f5f3;
  border-radius: 12rpx;
}

/* ============================================================
   LAYER 2 V2: 今晚第一杯首页
   目标：大氛围图承接 + 生活方式入口 + 搜索仍然是主线
   ============================================================ */

.home-page {
  padding: 0;
  background: var(--page-bg);
}

.home-main {
  min-height: 100vh;
  padding-bottom: 72rpx;
  background:
    radial-gradient(circle at 92% 4%, rgba(111, 145, 183, 0.18) 0, rgba(111, 145, 183, 0) 260rpx),
    radial-gradient(circle at 4% 18%, rgba(246, 212, 107, 0.18) 0, rgba(246, 212, 107, 0) 260rpx),
    linear-gradient(180deg, #fbf7ee 0%, #f7efe3 48%, #fbf7ee 100%);
}

.home-hero {
  position: relative;
  min-height: 500rpx;
  overflow: hidden;
  border-bottom-left-radius: 46rpx;
  border-bottom-right-radius: 46rpx;
  box-shadow: 0 18rpx 54rpx rgba(80, 70, 50, 0.08);
}

.home-hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 1;
  transform: scale(1.04);
  transform-origin: 68% 38%;
}

.home-hero-wash {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 74% 26%, rgba(120, 216, 214, 0.08) 0, rgba(120, 216, 214, 0) 190rpx),
    linear-gradient(180deg, rgba(251, 247, 238, 0.02) 0%, rgba(251, 247, 238, 0.12) 42%, rgba(251, 247, 238, 0.82) 100%),
    linear-gradient(90deg, rgba(251, 247, 238, 0.96) 0%, rgba(251, 247, 238, 0.72) 37%, rgba(251, 247, 238, 0.08) 70%, rgba(234, 245, 247, 0.00) 100%);
}

.hero-profile {
  position: absolute;
  top: 34rpx;
  right: 34rpx;
  z-index: 2;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill);
  background: rgba(255, 252, 244, 0.72);
  color: var(--deep-green);
  font-size: 34rpx;
  box-shadow: 0 10rpx 28rpx rgba(80, 70, 50, 0.10);
  backdrop-filter: blur(12rpx);
}

.hero-note {
  position: absolute;
  top: 126rpx;
  right: 156rpx;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
  min-width: 116rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 248, 222, 0.56);
  color: #6f6a45;
  font-size: 19rpx;
  line-height: 1.25;
  transform: rotate(-4deg);
  opacity: 0.62;
  box-shadow: 0 8rpx 20rpx rgba(80, 70, 50, 0.06);
}

.hero-content {
  position: relative;
  z-index: 1;
  padding: 44rpx 34rpx 28rpx;
}

.hero-content::after {
  content: '';
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 14rpx;
  height: 180rpx;
  border-radius: 48rpx;
  background: linear-gradient(180deg, rgba(255, 252, 244, 0.18), rgba(255, 252, 244, 0.78));
  filter: blur(8rpx);
  z-index: -1;
}

.brand-mark {
  font-size: 56rpx;
  line-height: 1.04;
  color: #2c241b;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.brand-title {
  margin-top: 14rpx;
  color: var(--primary-green);
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.brand-slogan {
  margin-top: 104rpx;
  max-width: 520rpx;
  color: #6f786f;
  font-size: 25rpx;
  line-height: 1.45;
}

.search-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 106rpx;
  margin-top: 22rpx;
  padding: 16rpx 18rpx 16rpx 28rpx;
  border: 3rpx solid rgba(47, 143, 123, 0.42);
  border-radius: var(--radius-pill);
  background: rgba(255, 252, 244, 0.90);
  box-shadow:
    0 20rpx 52rpx rgba(47, 143, 123, 0.14),
    inset 0 2rpx 0 rgba(255,255,255,0.72);
  backdrop-filter: blur(16rpx);
}

.search-card.focused {
  border-color: rgba(47, 143, 123, 0.72);
  background: rgba(255, 252, 244, 0.96);
}

.search-icon {
  color: #1e251f;
  font-size: 44rpx;
  line-height: 1;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  min-width: 0;
  color: #2d302b;
  font-size: 28rpx;
}

.search-btn {
  flex-shrink: 0;
  min-width: 128rpx;
  height: 74rpx;
  margin: 0;
  padding: 0 30rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, #39b5aa 0%, var(--primary-green) 100%);
  color: #fffdf7;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 30rpx rgba(47, 143, 123, 0.20);
}

.demand-strip {
  margin-top: 20rpx;
  white-space: nowrap;
}

.demand-chip {
  display: inline-flex;
  flex-shrink: 0;
  margin-right: 12rpx;
  padding: 12rpx 22rpx;
  border: 1rpx solid rgba(47, 143, 123, 0.16);
  border-radius: var(--radius-pill);
  background: rgba(255, 252, 244, 0.72);
  color: var(--deep-green);
  box-shadow: 0 8rpx 22rpx rgba(80, 70, 50, 0.06);
}

.demand-label {
  color: inherit;
  border-bottom: 0;
  font-size: 24rpx;
  font-weight: 600;
}

.home-body {
  padding: 22rpx 28rpx 0;
}

.random-entry {
  position: relative;
  min-height: 240rpx;
  margin: 0 0 28rpx;
  overflow: hidden;
