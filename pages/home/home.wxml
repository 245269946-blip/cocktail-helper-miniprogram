<view class="page home-page">
  <!-- ====== LAYER 1: 启动欢迎页 ====== -->
  <view wx:if="{{showSplash}}" class="splash-page">
    <!-- 背景层：水彩风主视觉 -->
    <view class="splash-bg">
      <image class="splash-hero-image" src="/assets/layer1/splash-hero.png" mode="aspectFill" />
      <!-- 渐变遮罩 -->
      <view class="splash-overlay"></view>
    </view>

    <!-- 装饰元素：风铃（右上） -->
    <image class="furin-img" src="/assets/layer1/furin-deco.png" mode="aspectFit" />

    <!-- 24h营业标签（右侧） -->
    <view class="badge-24h">
      <text class="badge-24h-text">24小时营业</text>
    </view>

    <!-- 主内容区 -->
    <view class="splash-content">
      <!-- 标题组 -->
      <view class="splash-title-group">
        <text class="splash-title-line1">今夜，</text>
        <text class="splash-title-line2">先来一杯</text>
      </view>

      <!-- 副标题 -->
      <view class="splash-subtitle">
        <text>微醺一下，生活就慢了下来。</text>
        <text class="subtitle-lemon">🍋</text>
      </view>

      <!-- 便利贴小票装饰（左侧） -->
      <view class="receipt-note">
        <view class="receipt-header">
          <text class="receipt-title">便利店小票</text>
          <view class="receipt-dots"></view>
        </view>
        <view class="receipt-items">
          <view class="receipt-row"><text class="r-name">金汤力</text><text class="r-price">¥3.00</text></view>
          <view class="receipt-row"><text class="r-name">苏打水</text><text class="r-price">¥2.00</text></view>
          <view class="receipt-row"><text class="r-name">冰块</text><text class="r-price">¥18.80</text></view>
          <view class="receipt-divider"></view>
          <view class="receipt-row receipt-total"><text class="r-name">总计</text><text class="r-price">¥35.30</text></view>
        </view>
      </view>
      <image class="receipt-deco-img" src="/assets/layer1/receipt-deco.png" mode="aspectFit" />

      <!-- 对话气泡（右侧） -->
      <view class="speech-bubble">
        <text class="bubble-text">冰块 + 气泡</text>
        <text class="bubble-text">青柠 + 微醺</text>
        <text class="bubble-text bubble-tag">问问好❤️</text>
      </view>

      <!-- CTA 按钮 -->
      <button class="cta-button" bindtap="onStart">
        <text class="cta-text">开始今晚第一杯</text>
        <text class="cta-arrow">→</text>
      </button>
    </view>

    <!-- 底部品牌栏 -->
    <view class="splash-footer">
      <text class="footer-dot">🍋</text>
      <text class="footer-brand">调酒助手</text>
      <text class="footer-sep">/</text>
      <text class="footer-slogan">让好喝，触手可得</text>
    </view>
  </view>

  <!-- ====== LAYER 2: 今晚第一杯首页 ====== -->
  <view wx:else class="home-main">
    <view class="home-hero">
      <image class="home-hero-bg" src="/assets/scenes/scene-header.png" mode="aspectFill" />
      <view class="home-hero-wash"></view>
      <view class="hero-profile" bindtap="onTapProfile">⌾</view>
      <view class="hero-note">
        <text>冰块</text>
        <text>青柠</text>
        <text>气泡水</text>
      </view>

      <view class="hero-content">
        <view class="brand-mark brand-art">
          <view class="brand-art-small">今晚</view>
          <view class="brand-art-main">先来一杯</view>
        </view>
        <view class="brand-slogan">搜酒名、材料、口味，快速拿到能做的配方。</view>

        <view class="search-card {{isFocused ? 'focused' : ''}}">
          <view class="search-icon">⌕</view>
          <input class="search-input" value="{{keyword}}" bindinput="onInput" bindfocus="onFocus" bindblur="onBlur" confirm-type="search" bindconfirm="onSearch" placeholder="搜金汤力、气泡水、低酒感" />
          <button class="search-btn" bindtap="onSearch">搜索</button>
        </view>

        <scroll-view class="demand-strip" scroll-x enable-flex>
          <view wx:for="{{demandTags}}" wx:key="label" class="demand-chip" data-keyword="{{item.keyword}}" bindtap="onDemandTap">
            <text class="demand-label">{{item.label}}</text>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="home-body">
      <view class="random-entry" bindtap="onRandomDrinkTap">
        <view class="random-entry-copy">
          <view class="random-entry-kicker">Mood shuffle</view>
          <view class="random-entry-title">随机来一杯</view>
          <view class="random-entry-desc">每天抽一杯适合今天的调酒，带一句好运话。</view>
          <view class="random-entry-action">抽今天这一杯</view>
        </view>
        <view class="random-entry-orbit">
          <image wx:for="{{randomPreview}}" wx:key="id" class="random-orbit-img img-{{index}}" src="{{item.illustration || item.thumbnail}}" mode="aspectFill" />
          <view class="random-orbit-glow"></view>
        </view>
      </view>

      <view class="featured-block">
        <view class="section-head">
          <view>
            <view class="section-kicker">First drink</view>
            <view class="section-label">推荐第一杯</view>
          </view>
          <view class="section-action">左右滑动</view>
        </view>

        <scroll-view class="first-drink-scroll" scroll-x>
          <view class="first-drink-track">
            <view wx:for="{{featuredRecipes}}" wx:key="id" class="first-drink-card" data-id="{{item.id}}" bindtap="onRecipeTap">
              <image class="first-drink-bg" src="{{item.image}}" mode="aspectFill" />
              <view class="first-drink-wash"></view>
              <view class="first-drink-copy">
                <view class="first-demand">{{item.demand}}</view>
                <view class="first-name">{{item.name}}</view>
                <view class="first-reason">{{item.reason}}</view>
                <view class="first-meta">
                  <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="first-tag">{{tag}}</text>
                </view>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="section-head entry-head">
        <view>
          <view class="section-kicker">没有明确酒名？</view>
          <view class="section-label">按条件找配方</view>
        </view>
      </view>

      <view class="entry-cards">
        <view wx:for="{{toolEntries}}" wx:key="title" class="entry-card entry-{{item.theme}}" data-path="{{item.path}}" bindtap="onNavigate">
          <image class="entry-bg" src="{{item.image}}" mode="aspectFill" />
          <view class="entry-tint"></view>
          <view class="entry-deco entry-deco-{{item.theme}}"></view>
          <view class="entry-copy">
            <view class="entry-title">{{item.title}}</view>
            <view class="entry-desc">{{item.desc}}</view>
            <view class="entry-tags">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="entry-tag">{{tag}}</text>
            </view>
          </view>
          <view class="entry-arrow">›</view>
        </view>
      </view>

      <view class="soft-search-block">
        <view class="section-head compact">
          <view class="section-label small-label">常搜需求</view>
          <view wx:if="{{recentSearches.length}}" class="section-action">最近搜索已弱化</view>
        </view>
        <scroll-view class="hot-tags-scroll" scroll-x enable-flex>
          <view wx:for="{{hotKeywords}}" wx:key="*this" class="hot-tag" data-keyword="{{item}}" bindtap="onHotTap">{{item}}</view>
        </scroll-view>

        <scroll-view wx:if="{{recentSearches.length}}" class="recent-scroll" scroll-x enable-flex>
          <view wx:for="{{recentSearches}}" wx:key="*this" class="recent-chip" data-keyword="{{item}}" bindtap="onHotTap">
            <text class="chip-name">{{item}}</text>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>
</view>
