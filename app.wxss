page {
  min-height: 100%;
  color: #233836;
  background: #f8f1e4;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at 14% 2%, rgba(156, 225, 217, 0.34) 0, rgba(156, 225, 217, 0) 190rpx),
    radial-gradient(circle at 90% 10%, rgba(255, 223, 179, 0.46) 0, rgba(255, 223, 179, 0) 210rpx),
    linear-gradient(180deg, #fff8eb 0%, #edf9f6 48%, #f8f1e4 100%);
}

.section {
  margin-top: 28rpx;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #233836;
}

.section-subtitle {
  margin-top: 6rpx;
  color: #81766c;
  font-size: 25rpx;
  line-height: 1.55;
}

.card {
  padding: 24rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 28rpx;
  background:
    linear-gradient(145deg, rgba(255, 253, 247, 0.84), rgba(238, 250, 248, 0.68));
  box-shadow: 0 16rpx 40rpx rgba(57, 96, 102, 0.08);
  transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
}

.card:active {
  transform: translateY(-3rpx) scale(0.994);
  border-color: rgba(80, 169, 165, 0.34);
  box-shadow: 0 18rpx 42rpx rgba(57, 96, 102, 0.12);
}

.muted {
  color: #81766c;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.13);
  border-radius: 999rpx;
  color: #4e6863;
  background: rgba(255, 250, 239, 0.78);
  font-size: 24rpx;
}

.tag.active {
  color: #203b3b;
  border-color: rgba(80, 169, 165, 0.44);
  background: #dff5f1;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin: 0;
  border-radius: 999rpx;
  color: #fffdf8;
  background: linear-gradient(135deg, #2f7770 0%, #244d50 100%);
  font-size: 28rpx;
  line-height: 1;
  box-shadow: 0 14rpx 30rpx rgba(47, 119, 112, 0.22);
  transition: transform 150ms ease, opacity 150ms ease;
}

.button-primary:active,
.button-ghost:active {
  transform: scale(0.985);
  opacity: 0.86;
}

.button-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  margin: 0;
  border: 2rpx solid rgba(61, 119, 118, 0.14);
  border-radius: 999rpx;
  color: #233836;
  background: rgba(255, 253, 247, 0.82);
  font-size: 27rpx;
  line-height: 1;
}

button::after {
  border: 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #233836;
}

.body {
  color: #5d5045;
  font-size: 27rpx;
  line-height: 1.65;
}

.small {
  font-size: 24rpx;
  line-height: 1.5;
}

.soft-panel {
  border: 2rpx solid rgba(61, 119, 118, 0.12);
  border-radius: 30rpx;
  background: rgba(255, 253, 247, 0.78);
  box-shadow: 0 18rpx 42rpx rgba(57, 96, 102, 0.07);
}

.visual-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.asset-illo {
  flex: 0 0 auto;
  width: 132rpx;
  height: 108rpx;
  overflow: hidden;
  border-radius: 24rpx;
  border: 2rpx solid rgba(80, 169, 165, 0.12);
  background:
    radial-gradient(circle at 76% 20%, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0) 48rpx),
    linear-gradient(145deg, rgba(243, 255, 252, 0.78), rgba(255, 246, 230, 0.66));
  animation: soft-breath 4.8s ease-in-out infinite;
}

.asset-illo.large-asset {
  width: 100%;
  height: 300rpx;
  border-radius: 34rpx;
}

.asset-illo.bottle-asset {
  width: 154rpx;
  height: 122rpx;
}

.asset-image {
  display: block;
  width: 100%;
  height: 100%;
}

.fact-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.fact-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 44rpx;
  padding: 0 14rpx;
  border: 2rpx solid rgba(61, 119, 118, 0.1);
  border-radius: 999rpx;
  background: rgba(255, 250, 240, 0.64);
}

.fact-label {
  color: #9a8a7a;
  font-size: 21rpx;
}

.fact-value {
  color: #2f4f4a;
  font-size: 22rpx;
  font-weight: 700;
}

@keyframes soft-breath {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-3rpx);
  }
}

.drink-illo {
  position: relative;
  flex: 0 0 auto;
  width: 168rpx;
  height: 142rpx;
  overflow: hidden;
  border: 2rpx solid rgba(61, 119, 118, 0.14);
  border-radius: 30rpx;
  background: linear-gradient(145deg, #f7fff9 0%, #eaf7fb 100%);
}

.drink-illo.small-illo {
  width: 128rpx;
  height: 112rpx;
  border-radius: 24rpx;
}

.drink-illo.large-illo {
  width: 100%;
  height: 290rpx;
  border-radius: 34rpx;
}

.illo-cup {
  position: absolute;
  left: 56rpx;
  bottom: 18rpx;
  width: 64rpx;
  height: 88rpx;
  border: 4rpx solid rgba(76, 62, 47, 0.64);
  border-top-width: 3rpx;
  border-radius: 14rpx 14rpx 22rpx 22rpx;
  transform: rotate(-3deg);
  background: rgba(255, 255, 255, 0.42);
}

.large-illo .illo-cup {
  left: 50%;
  bottom: 36rpx;
  width: 108rpx;
  height: 154rpx;
  margin-left: -54rpx;
  border-radius: 20rpx 20rpx 32rpx 32rpx;
}

.illo-liquid {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  height: 54rpx;
  border-radius: 8rpx 8rpx 16rpx 16rpx;
  background: linear-gradient(180deg, #bfe9ec 0%, #8fd6d0 100%);
}

.large-illo .illo-liquid {
  height: 94rpx;
  border-radius: 12rpx 12rpx 24rpx 24rpx;
}

.illo-ice {
  position: absolute;
  width: 18rpx;
  height: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 5rpx;
  background: rgba(255, 255, 255, 0.38);
}

.ice-a {
  left: 14rpx;
  bottom: 40rpx;
  transform: rotate(12deg);
}

.ice-b {
  right: 13rpx;
  bottom: 28rpx;
  transform: rotate(-10deg);
}

.illo-bubble {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid rgba(111, 183, 196, 0.45);
  border-radius: 50%;
}

.bubble-a {
  top: 24rpx;
  left: 34rpx;
}

.bubble-b {
  top: 48rpx;
  right: 32rpx;
  width: 9rpx;
  height: 9rpx;
}

.bubble-c {
  top: 72rpx;
  left: 22rpx;
  width: 7rpx;
  height: 7rpx;
}

.illo-fruit {
  position: absolute;
  left: 46rpx;
  bottom: 70rpx;
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid #a8d86f;
  border-radius: 50%;
  background: #f8f6a8;
  transform: rotate(-16deg);
}

.large-illo .illo-fruit {
  left: 50%;
  bottom: 142rpx;
  margin-left: -62rpx;
  width: 44rpx;
  height: 44rpx;
}

.illo-leaf {
  position: absolute;
  right: 44rpx;
  bottom: 88rpx;
  width: 22rpx;
  height: 34rpx;
  border-radius: 22rpx 4rpx 22rpx 4rpx;
  background: #8ac9a5;
  transform: rotate(22deg);
}

.large-illo .illo-leaf {
  right: 50%;
  bottom: 178rpx;
  margin-right: -78rpx;
  width: 32rpx;
  height: 48rpx;
}

.illo-moon {
  position: absolute;
  right: 22rpx;
  top: 18rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ffe8a8;
  box-shadow: -9rpx 3rpx 0 #f7fff9;
}

.large-illo .illo-moon {
  right: 58rpx;
  top: 34rpx;
  width: 44rpx;
  height: 44rpx;
  box-shadow: -13rpx 4rpx 0 #f7fff9;
}

.illo-shelf {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 15rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: rgba(76, 62, 47, 0.12);
}

.illo-fresh {
  background: linear-gradient(145deg, #f4fff8 0%, #e7f8ff 100%);
}

.illo-fresh .illo-liquid {
  background: linear-gradient(180deg, #c8f3f0 0%, #85d7d2 100%);
}

.illo-milky {
  background: linear-gradient(145deg, #fffaf0 0%, #f7efe1 100%);
}

.illo-milky .illo-liquid {
  background: linear-gradient(180deg, #fff2d8 0%, #dfc29c 100%);
}

.illo-fruity {
  background: linear-gradient(145deg, #fff8ed 0%, #ffe9ef 100%);
}

.illo-fruity .illo-liquid {
  background: linear-gradient(180deg, #ffd9b8 0%, #ff9f9a 100%);
}

.illo-tipsy {
  background: linear-gradient(145deg, #fff7f2 0%, #f0ecff 100%);
}

.illo-tipsy .illo-liquid {
  background: linear-gradient(180deg, #f2c7e8 0%, #b7aadf 100%);
}

.illo-convenience {
  background: linear-gradient(145deg, #f8fff7 0%, #eff7ff 48%, #fff4e4 100%);
}

.illo-convenience .illo-liquid {
  background: linear-gradient(180deg, #cbe9ff 0%, #95d6bd 100%);
}

.sketch-icon {
  position: relative;
  flex: 0 0 auto;
  width: 62rpx;
  height: 62rpx;
  border: 3rpx solid rgba(76, 62, 47, 0.58);
  border-radius: 20rpx;
  background: rgba(255, 253, 247, 0.65);
  transform: rotate(-3deg);
}

.sketch-icon::after {
  position: absolute;
  content: "";
}

.icon-store::after {
  left: 12rpx;
  right: 12rpx;
  top: 18rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #8fd6d0;
  box-shadow: 0 14rpx 0 #ffd9b8;
}

.icon-home::after {
  left: 15rpx;
  top: 13rpx;
  width: 30rpx;
  height: 30rpx;
  border-left: 4rpx solid #8ac9a5;
  border-bottom: 4rpx solid #8ac9a5;
  transform: rotate(135deg);
}

.icon-glass::after {
  left: 19rpx;
  top: 12rpx;
  width: 24rpx;
  height: 34rpx;
  border: 4rpx solid #85d7d2;
  border-top-width: 3rpx;
  border-radius: 6rpx 6rpx 12rpx 12rpx;
}

.icon-first::after {
  left: 15rpx;
  top: 15rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #ffd0dc;
  box-shadow: 18rpx -10rpx 0 -7rpx #ffe8a8;
}

.theme-sparkling .asset-illo,
.theme-gin .asset-illo,
.theme-vodka .asset-illo {
  background:
    radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0) 60rpx),
    linear-gradient(145deg, rgba(236, 255, 251, 0.86), rgba(224, 246, 255, 0.76));
}

.theme-coffee .asset-illo,
.theme-baileys .asset-illo {
  background:
    radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 60rpx),
    linear-gradient(145deg, rgba(255, 247, 232, 0.9), rgba(238, 218, 190, 0.74));
}

.theme-tea .asset-illo,
.theme-sake .asset-illo {
  background:
    radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0) 60rpx),
    linear-gradient(145deg, rgba(250, 255, 237, 0.88), rgba(224, 241, 218, 0.74));
}

.theme-juice .asset-illo,
.theme-rum .asset-illo,
.theme-tequila .asset-illo,
.theme-plum-wine .asset-illo {
  background:
    radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 60rpx),
    linear-gradient(145deg, rgba(255, 248, 232, 0.9), rgba(255, 224, 213, 0.76));
}

.theme-convenience .asset-illo {
  background:
    radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0) 70rpx),
    linear-gradient(145deg, rgba(238, 255, 252, 0.88), rgba(226, 242, 255, 0.76) 54%, rgba(255, 246, 226, 0.72));
}
